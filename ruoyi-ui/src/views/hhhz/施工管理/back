<el-col :span="4" v-if="false">
        <!--      <el-col :span="4" v-if="currentStep===3||currentStep===4">-->

        <!--        <el-button style="margin-top: 20px;margin-left: -80px;" @click="changePage(1)" icon="el-icon-back">返回数据页
                </el-button>-->
        <el-collapse v-model="activeNames" style="margin-left: -80px;margin-right: 0px">
          <el-collapse-item title="" name="1">
            <template slot="title">
              <h3 style="width: 100%;padding-left: 10px;">空白带信息</h3>
            </template>
            <el-scrollbar style="overflow-x: hidden;">
              <el-table
                  key="uuid"
                  v-if="!noneEmptyBand && emptyBandInfoList.length>0"
                  :data="emptyBandInfoList"
                  :default-sort="{prop: 'volume', order: 'descending'}"
                  height="250"
              >
                <el-table-column label="空白带编号" prop="uuid" width="85px" :formatter="sub5" align="center"/>
                <el-table-column label="中心点坐标" prop="position" :formatter="fixed2"
                                 align="center"></el-table-column>
                <el-table-column label="体积(m³)" prop="volume" width="75px" align="center"/>
                <el-table-column label="操作" prop="volume" width="55px" align="center">
                  <template slot-scope="scope">
                    <el-button @click="seeEmptyBand(scope.row)" type="text" icon="el-icon-eye" size="small">定位
                    </el-button>
                  </template>
                </el-table-column>
              </el-table>
              <div v-if="noneEmptyBand || emptyBandInfoList.length===0" style="width: 100%;text-align: center">
                <h3 style="color: #00afff">未发现任何空白带</h3>
              </div>
            </el-scrollbar>
          </el-collapse-item>
          <el-collapse-item name="2" v-if="emptyBandInfoList.length>0">
            <template slot="title">
              <h3 style="width: 100%;padding-left: 10px;">补钻操作区</h3>
            </template>
            <el-form style="display: inline-block;float: left" size="small" :inline="true">
              <div style="padding: 10px 10px 10px 10px">
                <el-form-item label="补钻算法">
                  <el-select v-model="addDrillForm.workPlace">
                    <el-option
                        v-for="item in workPlaces"
                        :key="item.id"
                        :label="item.label"
                        :value="item.id"
                    />
                  </el-select>
                </el-form-item>
                <!--<el-form-item label="施工点选择">
                  <el-radio-group v-model="addDrillForm.workPlace">
                    <el-radio :label="1">原始施工点</el-radio>
                    <el-radio :label="2">巷道最近点</el-radio>
                  </el-radio-group>
                </el-form-item>-->
                <!--              <el-collapse>
                                <el-collapse-item title="手动补钻" name="1">-->
                <el-form-item label="补钻抽采半径">
                  <el-input v-model="addDrillRadius"
                            size="mini"
                            style="width: 110px"
                            @blur="addDrillRadius !='' ? Number(addDrillRadius):0">
                    <template slot="append">m</template>
                  </el-input>
                </el-form-item>
                <br>
                <el-form-item label="开启手动补钻模式">
                  <el-switch v-model="addDrillForm.drillDesMode" @change="desModStatChange"></el-switch>
                </el-form-item>
                <br>
                <el-form-item label="全自动补钻模式">
                  <el-button type="primary" size="mini" @click="autoAddDrillLoading">一键自动补钻</el-button>
                </el-form-item>
                <br>
                <el-form-item label="补钻体积 >">
                  <el-input v-model="addEmptyVolumeThreshold"
                            size="mini"
                            style="width: 110px"
                            @blur="addEmptyVolumeThreshold !='' ? Number(addEmptyVolumeThreshold):0">
                    <template slot="append">m³</template>
                  </el-input>
                  <el-tooltip style="margin-left: 5px" effect="light" content="空白带体积小于该阈值将不会被自动补钻"
                              placement="top">
                    <i class="el-icon-info"></i>
                  </el-tooltip>
                </el-form-item>
                <br>
                <el-form-item label="补钻参数">
                  <el-button type="primary" size="mini" @click="showAddDrillData"
                             style="margin-bottom: 5px;margin-right: 5px">
                    显示补钻参数表
                  </el-button>
                </el-form-item>
              </div>
            </el-form>
          </el-collapse-item>
          <el-collapse-item name="3">
            <template slot="title">
              <h3 style="width: 100%;padding-left: 10px;">显示元素控制</h3>
            </template>
            <div style="padding: 10px 10px 10px 10px">
              <el-form size="mini" :inline="true">
                <span>煤层</span>
                <br>
                <el-form-item label="煤层体">
                  <el-switch
                      v-model="param.showCoalCube"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideCoal"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="煤层顶板">
                  <el-switch
                      v-model="param.showCoalTopMesh"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideTop"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="煤层底板">
                  <el-switch
                      v-model="param.showCoalBottomMesh"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideBottom"
                      :width="30"
                  />
                </el-form-item>
                <br>
                <span>实钻钻孔</span>
                <br>
                <el-form-item label="实钻钻孔">
                  <el-switch
                      v-model="param.showOriginDrill"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideOriginDrill"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="煤孔段">
                  <el-switch
                      v-model="param.showOriginDrillInCoal"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideOriginDrillInCoal"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="过煤段">
                  <el-switch
                      v-model="param.showOriginDrillBeyondCoal"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideOriginDrillBeyondCoal"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="抽采范围">
                  <el-switch
                      v-model="param.showOriginDrillRange"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideOriginDrillRange"
                      :width="30"
                  />
                </el-form-item>
                <!--                <el-form-item label="按列显示元素" label-width="90px" prop="threshold">
                                  &lt;!&ndash;              <el-cascader
                                                    v-model="groupDrillSelects"
