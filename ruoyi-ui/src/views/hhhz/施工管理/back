                                </el-form-item>-->
                <br>
                <span>补空白设计钻孔</span>
                <br>
                <el-form-item label="补钻钻孔">
                  <el-switch
                      v-model="param.showAddDrill"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideAddDrill"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="煤孔段">
                  <el-switch
                      v-model="param.showAddDrillInCoal"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideAddDrillInCoal"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="抽采范围">
                  <el-switch
                      v-model="param.showAddDrillRange"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideAddDrillRange"
                      :width="30"
                  />
                </el-form-item>
                <br>
                <span>空白带</span>
                <br>
                <el-form-item label="初始空白带">
                  <el-switch
                      v-model="param.showOriginEmptyBand"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideOriginEmptyBand"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="剩余空白带">
                  <el-switch
                      v-model="param.showEmptyBand"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideEmptyBand"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="包围盒">
                  <el-switch
                      v-model="param.showOutCube"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideEmptyBandCube"
                      :width="30"
                  />
                </el-form-item>
                <br>
                <span>巷道元素</span>
                <br>
                <el-form-item label="巷道">
                  <el-switch
                      v-model="param.showRoad"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideRoad"
                      :width="30"
                  />
                </el-form-item>
                <el-form-item label="施工点位">
                  <el-switch
                      v-model="param.showWorkPoint"
                      active-color="#409eff"
                      inactive-color="#eaecf0"
                      @change="showOrHideWorkPoint"
                      :width="30"
                  />
                </el-form-item>
                <br>
                <span>CAD预览</span>
                <br>
                <el-form-item label="钻孔平面图">
                  <el-button type="primary" size="mini" @click="showCADPage(null,1,2)"
                             style="margin-bottom: 5px;margin-right: 5px">
                    预览平面图
                  </el-button>
                  <el-button type="primary" size="mini" @click="showCADPage(null,1,3)"
                             style="margin-bottom: 5px;margin-right: 5px">
                    预览剖面图
                  </el-button>
                </el-form-item>
                <br>
                <div v-if="emptyBandInfoList.length<=0">
                  <span>参数信息</span>
                  <br>
                  <el-form-item label="补钻参数">
                    <el-button type="primary" size="mini" @click="showAddDrillData"
                               style="margin-bottom: 5px;margin-right: 5px">
                      显示补钻参数表
                    </el-button>
                  </el-form-item>
                  <br>
                  <!--                  <el-form-item label="补钻CAD图">
                                      <el-button type="primary" size="mini" @click="showCADPage"
                                                 style="margin-bottom: 5px;margin-right: 5px">
                                        显示补钻CAD图
                                      </el-button>
                                    </el-form-item>-->
                </div>
              </el-form>
