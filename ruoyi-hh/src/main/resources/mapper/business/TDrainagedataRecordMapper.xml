<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.business.mapper.TDrainagedataRecordMapper">
    
    <resultMap type="TDrainagedataRecord" id="TDrainagedataRecordResult">
        <result property="id"    column="id"    />
        <result property="measurePointLocal"    column="measure_point_local"    />
        <result property="measurePointCode"    column="measure_point_code"    />
        <result property="dataTime"    column="data_time"    />
        <result property="dataType"    column="data_type"    />
        <result property="value"    column="value"    />
    </resultMap>

    <sql id="selectTDrainagedataRecordVo">
        select id, measure_point_local, measure_point_code, data_time, data_type,`value` from t_drainagedata_record
    </sql>

    <select id="selectTDrainagedataRecordList" parameterType="TDrainagedataRecord" resultMap="TDrainagedataRecordResult">
        <include refid="selectTDrainagedataRecordVo"/>
        <where>  
            <if test="id != null  and id != 0"> and id = #{id}</if>
            <if test="measurePointLocal != null  and measurePointLocal != ''"> and measure_point_local = #{measurePointLocal}</if>
            <if test="measurePointCode != null  and measurePointCode != ''"> and measure_point_code = #{measurePointCode}</if>
            <if test="dataTime != null "> and data_time = #{dataTime}</if>
            <if test="dataType != null  and dataType != ''"> and data_type = #{dataType}</if>
            <if test="value != null  and value != ''"> and `value` = #{value}</if>
            <if test="createTime != null  and createTime != ''"> and create_time = #{createTime}</if>
        </where>
    </select>
    
    <select id="selectTDrainagedataRecordById" parameterType="Integer" resultMap="TDrainagedataRecordResult">
        <include refid="selectTDrainagedataRecordVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertTDrainagedataRecord" parameterType="TDrainagedataRecord" useGeneratedKeys="true" keyProperty="id">
        insert into t_drainagedata_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="measurePointLocal != null">measure_point_local,</if>
            <if test="measurePointCode != null">measure_point_code,</if>
            <if test="dataTime != null">data_time,</if>
            <if test="dataType != null">data_type,</if>
            <if test="value != null">`value`,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="measurePointLocal != null">#{measurePointLocal},</if>
            <if test="measurePointCode != null">#{measurePointCode},</if>
            <if test="dataTime != null">#{dataTime},</if>
            <if test="dataType != null">#{dataType},</if>
            <if test="value != null">#{value},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
         </trim>
    </insert>

    <update id="updateTDrainagedataRecord" parameterType="TDrainagedataRecord">
        update t_drainagedata_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="measurePointLocal != null">measure_point_local = #{measurePointLocal},</if>
            <if test="measurePointCode != null">measure_point_code = #{measurePointCode},</if>
            <if test="dataTime != null">data_time = #{dataTime},</if>
            <if test="dataType != null">data_type = #{dataType},</if>
            <if test="value != null">`value` = #{value},</if>
            update_time=
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTDrainagedataRecordById" parameterType="Integer">
        delete from t_drainagedata_record where id = #{id}
    </delete>

    <delete id="deleteTDrainagedataRecordByIds" parameterType="String">
        delete from t_drainagedata_record where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>