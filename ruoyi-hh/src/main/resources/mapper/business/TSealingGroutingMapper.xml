    <sql id="selectTSealingGroutingVo">
        select r.roadway,a.group_no,a.borehole_no,a.tube_length,h.hole_seal_type,sh.shift_info,s.*
        from t_sealing_grouting s
        LEFT JOIN t_actual_borehole a ON a.id=s.borehole_id
        LEFT JOIN t_roadway r ON a.roadway_id =r.id
        LEFT JOIN t_holeseal_type h ON h.id=s.holeseal_type_id
        LEFT JOIN t_shiftinfo sh ON sh.id=s.shift_id

    </sql>

