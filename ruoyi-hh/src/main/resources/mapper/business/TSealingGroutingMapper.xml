    <select id="getSealingGroutingRecord" resultType="com.ruoyi.hh.business.domain.TSealingGrouting">
        select r.roadway,a.group_no,a.borehole_no,s.grouting_date,a.tube_length,
        s.*
        from t_sealing_grouting s
        LEFT JOIN t_actual_borehole a ON s.borehole_id=a.Id
        LEFT JOIN t_roadway r ON a.roadway_id=r.Id
        LEFT JOIN t_shiftinfo sh ON sh.id=s.shift_id
        where 1=1
        <if test="groutingDate!=null">
            and s.grouting_date = #{groutingDate}
        </if>
        <if test="roadwayId!=null">AND r.id IN
            <foreach collection="roadwayId" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="groupNo!=null">AND a.group_no IN
            <foreach collection="groupNo" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="boreholeNo!=null">AND a.borehole_no IN
            <foreach collection="boreholeNo" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="groutingPerson!=null">AND s.grouting_person IN
            <foreach collection="groutingPerson" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
          <if test="shiftId!=null">
              AND s.shift_id =#{shiftId}
          </if>
    </select>

