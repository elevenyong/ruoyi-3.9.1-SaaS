<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.business.mapper.TGasremnantStatisticsMapper">
    
    <resultMap type="TGasremnantStatistics" id="TGasremnantStatisticsResult">
        <result property="id"    column="id"    />
        <result property="workfaceId"    column="workface_id"    />
        <result property="boreholeCode"    column="borehole_code"    />
        <result property="local"    column="local"    />
        <result property="depth"    column="depth"    />
        <result property="dip"    column="dip"    />
        <result property="azimuth"    column="azimuth"    />
        <result property="gasContentRemnant"    column="gas_content_remnant"    />
        <result property="gasPressureRemnant"    column="gas_pressure_remnant"    />
        <result property="recorder"    column="recorder"    />
    </resultMap>

    <sql id="selectTGasremnantStatisticsVo">
        select id, workface_id, borehole_code, local, depth, dip, azimuth, gas_content_remnant, gas_pressure_remnant, recorder from t_gasremnant_statistics
    </sql>

    <select id="selectTGasremnantStatisticsList" parameterType="TGasremnantStatistics" resultMap="TGasremnantStatisticsResult">
        <include refid="selectTGasremnantStatisticsVo"/>
        <where>  
            <if test="workfaceId != null and workfaceId != 0 "> and workface_id = #{workfaceId}</if>
            <if test="boreholeCode != null  and boreholeCode != ''"> and borehole_code = #{boreholeCode}</if>
            <if test="local != null  and local != ''"> and local = #{local}</if>
            <if test="depth != null "> and depth = #{depth}</if>
            <if test="dip != null "> and dip = #{dip}</if>
            <if test="azimuth != null "> and azimuth = #{azimuth}</if>
            <if test="gasContentRemnant != null "> and gas_content_remnant = #{gasContentRemnant}</if>
            <if test="gasPressureRemnant != null "> and gas_pressure_remnant = #{gasPressureRemnant}</if>
            <if test="recorder != null  and recorder != ''"> and recorder = #{recorder}</if>
        </where>
    </select>
    
    <select id="selectTGasremnantStatisticsById" parameterType="Integer" resultMap="TGasremnantStatisticsResult">
        <include refid="selectTGasremnantStatisticsVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertTGasremnantStatistics" parameterType="TGasremnantStatistics" useGeneratedKeys="true" keyProperty="id">
        insert into t_gasremnant_statistics
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="workfaceId != null and workfaceId != 0">workface_id,</if>
            <if test="boreholeCode != null">borehole_code,</if>
            <if test="local != null">local,</if>
            <if test="depth != null">depth,</if>
            <if test="dip != null">dip,</if>
            <if test="azimuth != null">azimuth,</if>
            <if test="gasContentRemnant != null">gas_content_remnant,</if>
            <if test="gasPressureRemnant != null">gas_pressure_remnant,</if>
            <if test="recorder != null">recorder,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="workfaceId != null and workfaceId != 0">#{workfaceId},</if>
            <if test="boreholeCode != null">#{boreholeCode},</if>
            <if test="local != null">#{local},</if>
            <if test="depth != null">#{depth},</if>
            <if test="dip != null">#{dip},</if>
            <if test="azimuth != null">#{azimuth},</if>
            <if test="gasContentRemnant != null">#{gasContentRemnant},</if>
            <if test="gasPressureRemnant != null">#{gasPressureRemnant},</if>
            <if test="recorder != null">#{recorder},</if>
         </trim>
    </insert>

    <update id="updateTGasremnantStatistics" parameterType="TGasremnantStatistics">
        update t_gasremnant_statistics
        <trim prefix="SET" suffixOverrides=",">
            <if test="workfaceId != null and workfaceId != 0">workface_id = #{workfaceId},</if>
            <if test="boreholeCode != null">borehole_code = #{boreholeCode},</if>
            <if test="local != null">local = #{local},</if>
            <if test="depth != null">depth = #{depth},</if>
            <if test="dip != null">dip = #{dip},</if>
            <if test="azimuth != null">azimuth = #{azimuth},</if>
            <if test="gasContentRemnant != null">gas_content_remnant = #{gasContentRemnant},</if>
            <if test="gasPressureRemnant != null">gas_pressure_remnant = #{gasPressureRemnant},</if>
            <if test="recorder != null">recorder = #{recorder},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTGasremnantStatisticsById" parameterType="Integer">
        delete from t_gasremnant_statistics where id = #{id}
    </delete>

    <delete id="deleteTGasremnantStatisticsByIds" parameterType="String">
        delete from t_gasremnant_statistics where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <!--根据工作面ID查询残存瓦斯含量统计表-->
    <select id="getByworkfaceId" parameterType="java.lang.Integer" resultType="com.ruoyi.hh.business.domain.TGasremnantStatistics">
        select * from t_gasremnant_statistics where workface_id=#{workfaceId}
    </select>
</mapper>