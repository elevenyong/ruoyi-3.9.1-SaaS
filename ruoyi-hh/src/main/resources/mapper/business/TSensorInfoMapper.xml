<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.business.mapper.TSensorInfoMapper">

    <resultMap type="TSensorInfo" id="TSensorInfoResult">
        <result property="id"    column="id"    />
        <result property="sensorCode"    column="sensor_code"    />
        <result property="sensorName"    column="sensor_name"    />
        <result property="sensorTypeId"    column="sensor_type_id"    />
        <result property="measurePointId"    column="measure_point_id"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTSensorInfoVo">
        select id, sensor_code, sensor_name, sensor_type_id, measure_point_id, create_by, create_time, update_by, update_time, remark from t_sensor_info
    </sql>

    <select id="selectTSensorInfoList" parameterType="TSensorInfo" resultMap="TSensorInfoResult">
        <include refid="selectTSensorInfoVo"/>
        <where>
            <if test="id!=null and id!=0">and id=#{id}</if>
            <if test="sensorCode != null  and sensorCode != ''"> and sensor_code = #{sensorCode}</if>
            <if test="sensorName != null  and sensorName != ''"> and sensor_name like concat('%', #{sensorName}, '%')</if>
            <if test="sensorTypeId != null and sensorTypeId != 0 "> and sensor_type_id = #{sensorTypeId}</if>
            <if test="measurePointId != null "> and measure_point_id = #{measurePointId}</if>
        </where>
    </select>

    <select id="selectTSensorInfoById" parameterType="Integer" resultMap="TSensorInfoResult">
        <include refid="selectTSensorInfoVo"/>
        where Id = #{id}
    </select>

    <insert id="insertTSensorInfo" parameterType="TSensorInfo" useGeneratedKeys="true" keyProperty="id">
        insert into t_sensor_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="sensorCode != null">sensor_code,</if>
            <if test="sensorName != null">sensor_name,</if>
            <if test="sensorTypeId != null and sensorTypeId != 0">sensor_type_id,</if>
            <if test="measurePointId != null">measure_point_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="sensorCode != null">#{sensorCode},</if>
            <if test="sensorName != null">#{sensorName},</if>
            <if test="sensorTypeId != null and sensorTypeId != 0">#{sensorTypeId},</if>
            <if test="measurePointId != null">#{measurePointId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTSensorInfo" parameterType="TSensorInfo">
        update t_sensor_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="sensorCode != null">sensor_code = #{sensorCode},</if>
            <if test="sensorName != null">sensor_name = #{sensorName},</if>
            <if test="sensorTypeId != null and sensorTypeId != 0">sensor_type_id = #{sensorTypeId},</if>
            <if test="measurePointId != null">measure_point_id = #{measurePointId},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where Id = #{id}
    </update>

    <delete id="deleteTSensorInfoById" parameterType="java.lang.Integer">
        delete from t_sensor_info where id = #{id}
    </delete>

    <delete id="deleteTSensorInfoByIds" parameterType="java.util.List">
        delete from t_sensor_info where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!--获取所有列表-->
    <select id="getPageList" resultType="com.ruoyi.hh.business.domain.TSensorInfo">
        <include refid="selectTSensorInfoVo"/>
    </select>
    <!--根据测点ID删除传感器信息id-->
    <delete id="delByMeasurePointIds" parameterType="java.util.List">
        delete from t_sensor_info where measure_point_id in
        <foreach item="measurePointIds" collection="list" open="(" separator="," close=")">
            #{measurePointIds}
        </foreach>
    </delete>
    <delete id="delByMeasurePointId" parameterType="java.lang.Integer">
        delete from t_sensor_info where measure_point_id=#{measurePointId }
    </delete>
    <!--根据测点ID查询传感器信息ID-->
    <select id="getIdsByMeasurePointId" parameterType="java.lang.Integer" resultType="java.lang.Integer">
        select id from t_sensor_info where measure_point_id=#{measurePointId }
    </select>

</mapper>