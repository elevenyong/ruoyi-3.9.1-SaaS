<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.business.mapper.TBkSensorDataMapper">

    <resultMap type="TBkSensorData" id="TBkSensorDataResult">
        <result property="id"    column="id"    />
        <result property="coalMineName"    column="coal_mine_name"    />
        <result property="measurePointCode"    column="measure_point_code"    />
        <result property="sensorTypeName"    column="sensor_type_name"    />
        <result property="measurePointLocal"    column="measure_point_local"    />
        <result property="measurePointValue"    column="measure_point_value"    />
        <result property="unit"    column="unit"    />
        <result property="status"    column="status"    />
        <result property="time"    column="time"    />
    </resultMap>

    <sql id="selectTBkSensorDataVo">
        select id,coal_mine_name, measure_point_code, sensor_type_name, measure_point_local, measure_point_value, unit, status, time from t_bk_sensor_data
    </sql>

    <select id="selectTBkSensorDataList" parameterType="com.ruoyi.hh.business.domain.TBkSensorData" resultMap="TBkSensorDataResult">
        <include refid="selectTBkSensorDataVo"/>
        <where>
            <if test="coalMineName != null  and coalMineName != ''"> and coal_mine_name = #{coalMineName}</if>
            <if test="measurePointCode != null  and measurePointCode != ''"> and measure_point_code = #{measurePointCode}</if>
            <if test="sensorTypeName != null  and sensorTypeName != ''"> and sensor_type_name like concat('%', #{sensorTypeName}, '%')</if>
            <if test="measurePointLocal != null  and measurePointLocal != ''"> and measure_point_local = #{measurePointLocal}</if>
            <if test="measurePointValue != null  and measurePointValue != ''"> and measure_point_value = #{measurePointValue}</if>
            <if test="unit != null  and unit != ''"> and unit = #{unit}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="time != null "> and time = #{time}</if>
        </where>
    </select>

    <select id="selectTBkSensorDataById" parameterType="Integer" resultMap="TBkSensorDataResult">
        <include refid="selectTBkSensorDataVo"/>
        where id = #{id}
    </select>

    <insert id="insertTBkSensorData" parameterType="com.ruoyi.hh.business.domain.TBkSensorData">
        insert into t_bk_sensor_data
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="coalMineName != null">coal_mine_name,</if>
            <if test="measurePointCode != null">measure_point_code,</if>
            <if test="sensorTypeName != null">sensor_type_name,</if>
            <if test="measurePointLocal != null">measure_point_local,</if>
            <if test="measurePointValue != null">measure_point_value,</if>
            <if test="unit != null">unit,</if>
            <if test="status != null">status,</if>
            <if test="time != null">time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="coalMineName != null">#{coalMineName},</if>
            <if test="measurePointCode != null">#{measurePointCode},</if>
            <if test="sensorTypeName != null">#{sensorTypeName},</if>
            <if test="measurePointLocal != null">#{measurePointLocal},</if>
            <if test="measurePointValue != null">#{measurePointValue},</if>
            <if test="unit != null">#{unit},</if>
            <if test="status != null">#{status},</if>
            <if test="time != null">#{time},</if>
         </trim>
    </insert>

    <update id="updateTBkSensorData" parameterType="com.ruoyi.hh.business.domain.TBkSensorData">
        update t_bk_sensor_data
        <trim prefix="SET" suffixOverrides=",">
            <if test="coalMineName != null">coal_mine_name = #{coalMineName},</if>
            <if test="measurePointCode != null">measure_point_code = #{measurePointCode},</if>
            <if test="sensorTypeName != null">sensor_type_name = #{sensorTypeName},</if>
            <if test="measurePointLocal != null">measure_point_local = #{measurePointLocal},</if>
            <if test="measurePointValue != null">measure_point_value = #{measurePointValue},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="status != null">status = #{status},</if>
            <if test="time != null">time = #{time},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTBkSensorDataById" parameterType="Integer">
        delete from t_bk_sensor_data where id = #{id}
    </delete>


