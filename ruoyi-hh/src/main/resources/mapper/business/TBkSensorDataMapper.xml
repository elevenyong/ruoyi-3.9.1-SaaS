    <!--获取指定日期的第一包数据-->
    <select id="getFirstDataSomeDay_Time" resultType="com.ruoyi.hh.business.domain.TBkSensorData">
        SELECT measure_point_code, MIN(time) AS min_timestamp
        FROM t_bk_sensor_data where time between #{startTime} and #{endTime}
        <if test="measurePointLocal!=null">
            and measure_point_local like "%${measurePointLocal}%"
        </if>
        GROUP BY measure_point_code
    </select>
    <!--获取指定日期的最后一包数据-->
    <select id="getLastDataSomeDay_Time" resultType="com.ruoyi.hh.business.domain.TBkSensorData">
        SELECT measure_point_code, MAX(time) AS min_timestamp
        FROM t_bk_sensor_data where time between #{startTime} and #{endTime}
        <if test="measurePointLocal!=null">
            and measure_point_local like "%${measurePointLocal}%"
        </if>
        GROUP BY measure_point_code
    </select>
    <!--获取某一天的所有数据-->
    <select id="getDataSomeDay_All" resultMap="TBkSensorDataResult">
        select * from t_bk_sensor_data where time between #{startTime}
        and #{endTime} and measure_point_local like "%${measurePointLocal}%" ORDER BY time desc
    </select>
    <!--获取某一天的，指定传感器的数据-->
    <select id="getDataByLocal_All" resultMap="TBkSensorDataResult">
        select * from t_bk_sensor_data where time between #{startTime}
        and #{endTime}
        <if test="measurePointLocal!=null">and measure_point_local in
            <foreach collection="measurePointLocal" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
    </select>

    <!--获取某一天所有测点的最后一包数据-->
    <select id="getAllDataLast_Time" resultMap="TBkSensorDataResult">
        SELECT measure_point_code, MIN(time) AS min_timestamp
        FROM t_bk_sensor_data where time between #{startTime} and #{endTime} and measure_point_local like "%${measurePointLocal}%"
        GROUP BY measure_point_code
    </select>

    <!--(抽采历史曲线)时间内某测点编码，某测点类型数据-->
    <select id="getHistoricalCurve" resultMap="TBkSensorDataResult">
        SELECT * from t_bk_sensor_data

                 WHERE time BETWEEN #{startTime} and #{endTime}
        <if test="measurePointCode!=null">
            and measure_point_code=#{measurePointCode}
        </if>
        <if test="sensorTypeName!=null">
            and sensor_type_name=#{sensorTypeName}
        </if>
    </select>

    <!--查询某天的所有日累计测点位置信息-->
    <select id="getDayLocal" resultType="string">
        select measure_point_local from t_bk_sensor_data where sensor_type_name = "瓦斯日累计纯量" and time between #{startTime} and #{endTime} GROUP BY measure_point_local
    </select>
    <!--查询某天的所有月累计测点位置信息-->
    <select id="getMonthLocal" resultType="string">
        select measure_point_local from t_bk_sensor_data where sensor_type_name = "瓦斯月累计纯量" and time between #{startTime} and #{endTime} GROUP BY measure_point_local
    </select>
    <!--查询某天测所有抽放量的测点位置信息-->
    <select id="getDrainageLocal" resultType="string">
        select measure_point_local from t_bk_sensor_data where sensor_type_name = "瓦斯抽放量" and time between #{startTime} and #{endTime} GROUP BY measure_point_local
    </select>
</mapper>
