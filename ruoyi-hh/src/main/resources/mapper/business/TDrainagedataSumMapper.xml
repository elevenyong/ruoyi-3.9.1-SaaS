<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.business.mapper.TDrainagedataSumMapper">
    
    <resultMap type="TDrainagedataSum" id="TDrainagedataSumResult">
        <result property="id"    column="id"    />
        <result property="drainageUnitId"    column="drainage_unit_id"    />
        <result property="drainageUnit"    column="drainage_unit"    />
        <result property="gasScalarMonth"    column="gasScalarMonth"    />
        <result property="gasScalar"    column="gas_scalar"    />
        <result property="drainageQuantity"    column="drainage_quantity"    />
        <result property="gasContentRemnant"    column="gas_content_remnant"    />
        <result property="gasReservesRemnant"    column="gas_reserves_remnant"    />
        <result property="gasCompleteRatio"    column="gas_complete_ratio"    />
        <result property="dataDate"    column="data_date"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectTDrainagedataSumVo">
        select id, drainage_unit_id,drainage_unit,gas_scalar_month, gas_scalar, drainage_quantity, gas_content_remnant, gas_reserves_remnant, gas_complete_ratio,data_date from t_drainagedata_sum
    </sql>

    <select id="selectTDrainagedataSumList" parameterType="TDrainagedataSum" resultMap="TDrainagedataSumResult">
        <include refid="selectTDrainagedataSumVo"/>
        <where>  
            <if test="drainageUnitid != null  and drainageUnit != 0"> and drainage_unit_id = #{drainageUnitId}</if>
            <if test="drainageUnit != null  and drainageUnit != ''"> and drainage_unit = #{drainageUnit}</if>
            <if test="gasScalarMonth != null "> and gas_scalar_month = #{gasScalarMonth}</if>
            <if test="gasScalar != null "> and gas_scalar = #{gasScalar}</if>
            <if test="drainageQuantity != null "> and drainage_quantity = #{drainageQuantity}</if>
            <if test="gasContentRemnant != null "> and gas_content_remnant = #{gasContentRemnant}</if>
            <if test="gasReservesRemnant != null "> and gas_reserves_remnant = #{gasReservesRemnant}</if>
            <if test="gasCompleteRatio != null "> and gas_complete_ratio = #{gasCompleteRatio}</if>
            <if test="dataDate != null "> and data_date = #{dataDate}</if>
            <if test="createTime != null "> and create_time = #{createTime}</if>
            <if test="updateTime != null "> and update_time = #{updateTime}</if>
        </where>
    </select>
    
    <select id="selectTDrainagedataSumById" parameterType="Integer" resultMap="TDrainagedataSumResult">
        <include refid="selectTDrainagedataSumVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertTDrainagedataSum" parameterType="TDrainagedataSum">
        insert into t_drainagedata_sum
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="drainageUnitId != null">drainage_unit_id,</if>
            <if test="drainageUnit != null">drainage_unit,</if>
            <if test="gasScalarMonth != null">gas_scalar_month,</if>
            <if test="gasScalar != null">gas_scalar,</if>
            <if test="drainageQuantity != null">drainage_quantity,</if>
            <if test="gasContentRemnant != null">gas_content_remnant,</if>
            <if test="gasReservesRemnant != null">gas_reserves_remnant,</if>
            <if test="gasCompleteRatio != null">gas_complete_ratio,</if>
            <if test="dataDate != null">data_date,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="drainageUnitId != null ">#{drainageUnitId},</if>
            <if test="drainageUnit != null">#{drainageUnit},</if>
            <if test="gasScalarMonth != null">#{gasScalarMonth},</if>
            <if test="gasScalar != null">#{gasScalar},</if>
            <if test="drainageQuantity != null">#{drainageQuantity},</if>
            <if test="gasContentRemnant != null">#{gasContentRemnant},</if>
            <if test="gasReservesRemnant != null">#{gasReservesRemnant},</if>
            <if test="gasCompleteRatio != null">#{gasCompleteRatio},</if>
            <if test="dataDate != null">#{dataDate},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
         </trim>
    </insert>

    <update id="updateTDrainagedataSum" parameterType="TDrainagedataSum">
        update t_drainagedata_sum
        <trim prefix="SET" suffixOverrides=",">
            <if test="drainageUnitId != null">drainage_unit_id = #{drainageUnitId},</if>
            <if test="drainageUnit != null">drainage_unit = #{drainageUnit},</if>
            <if test="gasScalarMonth != null">gas_scalar_month = #{gasScalarMonth},</if>
            <if test="gasScalar != null">gas_scalar = #{gasScalar},</if>
            <if test="drainageQuantity != null">drainage_quantity = #{drainageQuantity},</if>
            <if test="gasContentRemnant != null">gas_content_remnant = #{gasContentRemnant},</if>
            <if test="gasReservesRemnant != null">gas_reserves_remnant = #{gasReservesRemnant},</if>
            <if test="gasCompleteRatio != null">gas_complete_ratio = #{gasCompleteRatio},</if>
            <if test="dataDate != null">data_date = #{dataDate},</if>
            update_time=
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTDrainagedataSumById" parameterType="Integer">
        delete from t_drainagedata_sum where id = #{id}
    </delete>

    <delete id="deleteTDrainagedataSumByIds" parameterType="String">
        delete from t_drainagedata_sum where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>