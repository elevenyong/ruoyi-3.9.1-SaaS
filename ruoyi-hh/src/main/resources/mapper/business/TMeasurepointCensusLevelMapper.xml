<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.business.mapper.TMeasurepointCensusLevelMapper">

    <resultMap type="TMeasurepointCensusLevel" id="TMeasurepointCensusLevelResult">
        <result property="id"    column="id"    />
        <result property="levelName"    column="level_name"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTMeasurepointCensusLevelVo">
        select id, level_name, create_by, create_time, update_by, update_time, remark from t_measurepoint_census_level
    </sql>

    <select id="selectTMeasurepointCensusLevelList" parameterType="TMeasurepointCensusLevel" resultMap="TMeasurepointCensusLevelResult">
        <include refid="selectTMeasurepointCensusLevelVo"/>
        <where>
            <if test="id!=null and id!=0">and d.id=#{id}</if>
            <if test="levelName != null  and levelName != ''"> and level_name like concat('%', #{levelName}, '%')</if>
        </where>
    </select>

    <select id="selectTMeasurepointCensusLevelById" parameterType="Integer" resultMap="TMeasurepointCensusLevelResult">
        <include refid="selectTMeasurepointCensusLevelVo"/>
        where id = #{id}
    </select>

    <insert id="insertTMeasurepointCensusLevel" parameterType="TMeasurepointCensusLevel" useGeneratedKeys="true" keyProperty="id">
        insert into t_measurepoint_census_level
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="levelName != null">level_name,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="levelName != null">#{levelName},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTMeasurepointCensusLevel" parameterType="TMeasurepointCensusLevel">
        update t_measurepoint_census_level
        <trim prefix="SET" suffixOverrides=",">
            <if test="levelName != null">level_name = #{levelName},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTMeasurepointCensusLevelById" parameterType="Integer">
        delete from t_measurepoint_census_level where id = #{id}
    </delete>

    <delete id="deleteTMeasurepointCensusLevelByIds" parameterType="String">
        delete from t_measurepoint_census_level where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>


</mapper>
