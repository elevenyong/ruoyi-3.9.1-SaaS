<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.physical.mapper.TActDirectionalDrillingPointMapper">

    <resultMap type="TActDirectionalDrillingPoint" id="TActDirectionalDrillingPointResult">
        <result property="id" column="id"/>
        <result property="boreholeId" column="borehole_id"/>
        <result property="boreholeLength" column="borehole_length"/>
        <result property="azimuthAngle" column="azimuth_angle"/>
        <result property="inclinationAngle" column="inclination_angle"/>
        <result property="offset" column="offset"/>
        <result property="projectionDepth" column="projection_depth"/>
        <result property="offsetLR" column="offset_LR"/>
        <result property="offsetTD" column="offset_TD"/>
        <result property="offsetEast" column="offset_east"/>
        <result property="offsetNorth" column="offset_north"/>
        <result property="altitude" column="altitude"/>
        <result property="coalRockSituation" column="coal_rock_situation"/>
        <result property="index" column="index"/>
        <result property="addSpeed" column="add_speed"/>
        <result property="timer" column="timer"/>
        <result property="temp" column="temp"/>
        <result property="cichang" column="cichang"/>
        <result property="magneticDip" column="magnetic_dip"/>
        <result property="remark" column="remark"/>
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectTActDirectionalDrillingPointVo">
        select id,
               borehole_id,
               borehole_length,
               azimuth_angle,
               inclination_angle,
               offset,
               projection_depth,
               offset_LR,
               offset_TD,
               offset_east,
               offset_north,
               altitude,
               coal_rock_situation,
               `index`,
               add_speed,
               timer,
               temp,
               cichang,
               magnetic_dip,
               remark,
               create_time
        from t_act_directional_drilling_point
    </sql>

    <select id="selectTActDirectionalDrillingPointList" parameterType="TActDirectionalDrillingPoint"
            resultMap="TActDirectionalDrillingPointResult">
        <include refid="selectTActDirectionalDrillingPointVo"/>
        <where>
            <if test="id != null and id != 0">and id = #{id}</if>
            <if test="boreholeId != null and boreholeId != 0 ">and borehole_id = #{boreholeId}</if>
            <if test="boreholeLength != null ">and borehole_length = #{boreholeLength}</if>
            <if test="azimuthAngle != null ">and azimuth_angle = #{azimuthAngle}</if>
            <if test="inclinationAngle != null ">and inclination_angle = #{inclinationAngle}</if>
            <if test="offset != null ">and offset = #{offset}</if>
            <if test="projectionDepth != null ">and projection_depth = #{projectionDepth}</if>
            <if test="offsetLR != null ">and offset_LR = #{offsetLR}</if>
            <if test="offsetTD != null ">and offset_TD = #{offsetTD}</if>
            <if test="offsetEast != null ">and offset_east = #{offsetEast}</if>
            <if test="offsetNorth != null ">and offset_north = #{offsetNorth}</if>
            <if test="altitude != null ">and altitude = #{altitude}</if>
            <if test="coalRockSituation != null  and coalRockSituation != ''">and coal_rock_situation =
                #{coalRockSituation}
            </if>
            <if test="index != null  and index != ''">and `index` = #{index}</if>
            <if test="addSpeed != null  and addSpeed != ''">and add_speed = #{addSpeed}</if>
            <if test="timer != null  and timer != ''">and timer = #{timer}</if>
            <if test="temp != null  and temp != ''">and temp = #{temp}</if>
            <if test="cichang != null  and cichang != ''">and cichang = #{cichang}</if>
            <if test="magneticDip != null  and magneticDip != ''">and magnetic_dip = #{magneticDip}</if>
            <if test="remark != null  and remark != ''">and remark = #{remark}</if>
            <if test="createTime != null and createTime != ''">and create_time = #{createTime}</if>
        </where>
    </select>

    <select id="selectTActDirectionalDrillingPointById" parameterType="Integer"
            resultMap="TActDirectionalDrillingPointResult">
        <include refid="selectTActDirectionalDrillingPointVo"/>
        where id = #{id}
    </select>

    <insert id="insertTActDirectionalDrillingPoint" parameterType="TActDirectionalDrillingPoint" useGeneratedKeys="true"
            keyProperty="id">
        insert into t_act_directional_drilling_point
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="boreholeId != null and boreholeId != 0">borehole_id,</if>
            <if test="boreholeLength != null">borehole_length,</if>
            <if test="azimuthAngle != null">azimuth_angle,</if>
            <if test="inclinationAngle != null">inclination_angle,</if>
            <if test="offset != null">`offset`,</if>
            <if test="projectionDepth != null">projection_depth,</if>
            <if test="offsetLR != null">offset_LR,</if>
            <if test="offsetTD != null">offset_TD,</if>
            <if test="offsetEast != null">offset_east,</if>
            <if test="offsetNorth != null">offset_north,</if>
            <if test="altitude != null">altitude,</if>
            <if test="coalRockSituation != null">coal_rock_situation,</if>
            <if test="index != null">`index`,</if>
            <if test="addSpeed != null  and addSpeed != ''">add_speed,</if>
            <if test="timer != null  and timer != ''">timer,</if>
            <if test="temp != null  and temp != ''">temp,</if>
            <if test="cichang != null  and cichang != ''">cichang,</if>
            <if test="magneticDip != null  and magneticDip != ''">magnetic_dip,</if>
            <if test="remark != null  and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="boreholeId != null and boreholeId != 0">#{boreholeId},</if>
            <if test="boreholeLength != null">#{boreholeLength},</if>
            <if test="azimuthAngle != null">#{azimuthAngle},</if>
            <if test="inclinationAngle != null">#{inclinationAngle},</if>
            <if test="offset != null">#{offset},</if>
            <if test="projectionDepth != null">#{projectionDepth},</if>
            <if test="offsetLR != null">#{offsetLR},</if>
            <if test="offsetTD != null">#{offsetTD},</if>
            <if test="offsetEast != null">#{offsetEast},</if>
            <if test="offsetNorth != null">#{offsetNorth},</if>
            <if test="altitude != null">#{altitude},</if>
            <if test="coalRockSituation != null">#{coalRockSituation},</if>
            <if test="index != null">#{index},</if>
            <if test="addSpeed != null  and addSpeed != ''">#{addSpeed},</if>
            <if test="timer != null  and timer != ''">#{timer},</if>
            <if test="temp != null  and temp != ''">#{temp},</if>
            <if test="cichang != null  and cichang != ''">#{cichang},</if>
            <if test="magneticDip != null  and magneticDip != ''">#{magneticDip},</if>
            <if test="remark != null  and remark != ''">#{remark},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTActDirectionalDrillingPoint" parameterType="TActDirectionalDrillingPoint">
        update t_act_directional_drilling_point
        <trim prefix="SET" suffixOverrides=",">
            <if test="boreholeId != null and boreholeId != 0">borehole_id = #{boreholeId},</if>
            <if test="boreholeLength != null">borehole_length = #{boreholeLength},</if>
            <if test="azimuthAngle != null">azimuth_angle = #{azimuthAngle},</if>
            <if test="inclinationAngle != null">inclination_angle = #{inclinationAngle},</if>
            <if test="offset != null">`offset` = #{offset},</if>
            <if test="projectionDepth != null">projection_depth = #{projectionDepth},</if>
            <if test="offsetLR != null">offset_LR = #{offsetLR},</if>
            <if test="offsetTD != null">offset_TD = #{offsetTD},</if>
            <if test="offsetEast != null">offset_east = #{offsetEast},</if>
            <if test="offsetNorth != null">offset_north = #{offsetNorth},</if>
            <if test="altitude != null">altitude = #{altitude},</if>
            <if test="coalRockSituation != null">coal_rock_situation = #{coalRockSituation},</if>
            <if test="index != null">`index` = #{index},</if>
            <if test="addSpeed != null  and addSpeed != ''">add_speed = #{addSpeed},</if>
            <if test="timer != null  and timer != ''">timer = #{timer},</if>
            <if test="temp != null  and temp != ''">temp = #{temp},</if>
            <if test="cichang != null  and cichang != ''">cichang = #{cichang},</if>
            <if test="magneticDip != null  and magneticDip != ''">magnetic_dip = #{magneticDip},</if>
            <if test="remark != null  and remark != ''">remark = #{remark}</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTActDirectionalDrillingPointById" parameterType="Integer">
        delete
        from t_act_directional_drilling_point
        where id = #{id}
    </delete>

    <delete id="deleteTActDirectionalDrillingPointByIds" parameterType="String">
        delete from t_act_directional_drilling_point where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!--根据实钻ID查询点位列表-->
    <select id="getPointByActBoreholeId" parameterType="java.lang.Integer"
            resultMap="TActDirectionalDrillingPointResult">
        select *
        from t_act_directional_drilling_point
        where borehole_id = #{boreholeId}
    </select>
</mapper>
