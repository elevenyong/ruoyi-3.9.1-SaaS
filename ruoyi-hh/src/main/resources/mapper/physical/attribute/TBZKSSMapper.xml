<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.physical.attribute.mapper.TBZKSSMapper">
    
    <resultMap type="TBZKSS" id="TBZKSSResult">
        <result property="id"    column="id"    />
        <result property="measurePointCode"    column="measure_point_code"    />
        <result property="sensorTypeName"    column="sensor_type_name"    />
        <result property="sensorLocal"    column="sensor_local"    />
        <result property="value"    column="value"    />
        <result property="status"    column="status"    />
        <result property="date"    column="date"    />
    </resultMap>

    <sql id="selectTBZKSSVo">
        select id, measure_point_code, sensor_type_name, sensor_local, value, status, date from t_stressmeter_data
    </sql>

    <select id="selectTBZKSSList" parameterType="TBZKSS" resultMap="TBZKSSResult">
        <include refid="selectTBZKSSVo"/>
        <where>  
            <if test="measurePointCode != null  and measurePointCode != ''"> and measure_point_code = #{measurePointCode}</if>
            <if test="sensorTypeName != null  and sensorTypeName != ''"> and sensor_type_name like concat('%', #{sensorTypeName}, '%')</if>
            <if test="sensorLocal != null  and sensorLocal != ''"> and sensor_local = #{sensorLocal}</if>
            <if test="value != null "> and value = #{value}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="date != null "> and date = #{date}</if>
        </where>
    </select>
    
    <select id="selectTBZKSSById" parameterType="Integer" resultMap="TBZKSSResult">
        <include refid="selectTBZKSSVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertTBZKSS" parameterType="TBZKSS">
        insert into t_stressmeter_data
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="measurePointCode != null">measure_point_code,</if>
            <if test="sensorTypeName != null">sensor_type_name,</if>
            <if test="sensorLocal != null">sensor_local,</if>
            <if test="value != null">value,</if>
            <if test="status != null">status,</if>
            <if test="date != null">date,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="measurePointCode != null">#{measurePointCode},</if>
            <if test="sensorTypeName != null">#{sensorTypeName},</if>
            <if test="sensorLocal != null">#{sensorLocal},</if>
            <if test="value != null">#{value},</if>
            <if test="status != null">#{status},</if>
            <if test="date != null">#{date},</if>
         </trim>
    </insert>

    <update id="updateTBZKSS" parameterType="TBZKSS">
        update t_stressmeter_data
        <trim prefix="SET" suffixOverrides=",">
            <if test="measurePointCode != null">measure_point_code = #{measurePointCode},</if>
            <if test="sensorTypeName != null">sensor_type_name = #{sensorTypeName},</if>
            <if test="sensorLocal != null">sensor_local = #{sensorLocal},</if>
            <if test="value != null">value = #{value},</if>
            <if test="status != null">status = #{status},</if>
            <if test="date != null">date = #{date},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTBZKSSById" parameterType="Integer">
        delete from t_stressmeter_data where id = #{id}
    </delete>

    <delete id="deleteTBZKSSByIds" parameterType="String">
        delete from t_stressmeter_data where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>