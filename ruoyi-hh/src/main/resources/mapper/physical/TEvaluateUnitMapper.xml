    <delete id="deleteTEvaluateUnitById" parameterType="Integer">
        delete from t_evaluate_unit where id = #{id}
    </delete>

    <delete id="deleteTEvaluateUnitByIds" parameterType="java.util.List">
        delete from t_evaluate_unit where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <!--分页查询-->
    <select id="getPageList" resultType="com.ruoyi.hh.physical.domain.TEvaluateUnit">
        <include refid="selectTEvaluateUnitVo"/>
    </select>
    <!--根据工作面ID查询评价单元-->
    <select id="getByWorkfaceId" resultType="com.ruoyi.hh.physical.domain.TEvaluateUnit" parameterType="java.lang.Integer">
        select * from t_evaluate_unit where workface_id =#{workfeceid}
    </select>
    <!--根据评价单元ID查询所属工作面信息-->
    <select id="getWorkfaceByEvaluateUnitId" resultType="com.ruoyi.hh.physical.domain.TWorkingFace" parameterType="java.lang.Integer">
        select w.* from t_working_face w
        LEFT JOIN t_evaluate_unit e
        ON w.id=e.workface_id
        where e.id=#{evaluateunitid}
    </select>

    <!--根据工作面ID或者评价单元ID查询评判报告相关信息-->
    <select id="getJudgeReportInfo" resultType="com.ruoyi.hh.physical.domain.TEvaluateUnit">
        select id,evaluate_unit_name,wide,length,accumulated_amount,area,coal_thickness,capacity,ROUND((area*coal_thickness*capacity),2) AS coal_reserves,
        ROUND((coal_reserves*gas_content_original-accumulated_amount),2)AS remnantgasreserves,
        ROUND(((coal_reserves*gas_content_original-accumulated_amount)/coal_reserves),2)AS remnantgascontentremnant,
        ROUND(accumulated_amount/(coal_reserves*gas_content_original),2) AS completeratio,
        gas_content_original,gas_total_reserves,start_construction,end_construction,
        DATEDIFF(end_time_L,start_time_L) AS daysL,DATEDIFF(end_time_S,start_time_S)AS daysS,
        (DATEDIFF(end_time_L,start_time_L)-DATEDIFF(end_time_S,start_time_S))/DATEDIFF(end_time_L,start_time_L) AS diff_coefficient
        from t_evaluate_unit
        where 1=1
        <if test="workfaceId!=null">
            AND
             workface_id =#{workfaceId}
         </if>
         <if test="evaluateunitid!=null">
             AND
             id=#{evaluateunitid}
         </if>
    </select>
