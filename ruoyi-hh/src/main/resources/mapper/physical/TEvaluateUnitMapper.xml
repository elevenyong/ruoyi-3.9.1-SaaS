    <sql id="selectTEvaluateUnitVo">
    select e.id, e.evaluate_unit_name, e.wide, e.length, e.coal_thickness, e.coal_reserves, e.area, e.capacity, e.workface_id,w.workface_name, e.gas_content_original,
           e.gas_total_reserves,e.start_construction,e.end_construction,e.accumulated_amount, e.longest_time_borehole_id, e.start_time_L, e.end_time_L,
           e.shortest_time_borehole_id, e.start_time_S, e.end_time_S, e.days_L, e.days_S, e.diff_coefficient, e.diff_coefficient_standard, e.create_time,
           e.create_by, e.update_time, e.update_by, e.remark from t_evaluate_unit e
    left join t_working_face w on e.workface_id =w.id
    </sql>

    <select id="selectTEvaluateUnitList" parameterType="TEvaluateUnit" resultMap="TEvaluateUnitResult">
        <include refid="selectTEvaluateUnitVo"/>
        <where>
            <if test="id != null and id != 0"> and e.id = #{id}</if>
            <if test="evaluateUnitName != null  and evaluateUnitName != ''"> and e.evaluate_unit_name like concat('%', #{evaluateUnitName}, '%')</if>
            <if test="wide != null "> and e.wide = #{wide}</if>
            <if test="length != null "> and e.length = #{length}</if>
            <if test="coalThickness != null "> and e.coal_thickness = #{coalThickness}</if>
            <if test="coalReserves != null "> and e.coal_reserves = #{coalReserves}</if>
            <if test="area != null "> and e.area = #{area}</if>
            <if test="capacity != null "> and e.capacity = #{capacity}</if>
            <if test="workfaceId != null and workfaceId != 0 "> and e.workface_id = #{workfaceId}</if>
            <if test="gasContentOriginal != null "> and e.gas_content_original = #{gasContentOriginal}</if>
            <if test="gasTotalReserves != null "> and e.gas_total_reserves = #{gasTotalReserves}</if>
            <if test="startConstruction != null "> and e.start_construction = #{startConstruction}</if>
            <if test="endConstruction != null "> and e.end_construction = #{endConstruction}</if>
            <if test="accumulatedAmount != null "> and e.accumulated_amount = #{accumulatedAmount}</if>
            <if test="longestTimeBoreholeId != null and longestTimeBoreholeId != 0 "> and e.longest_time_borehole_id = #{longestTimeBoreholeId}</if>
            <if test="startTimeL != null "> and e.start_time_L = #{startTimeL}</if>
            <if test="endTimeL != null "> and e.end_time_L = #{endTimeL}</if>
            <if test="shortestTimeBoreholeId != null "> and e.shortest_time_borehole_id = #{shortestTimeBoreholeId}</if>
            <if test="startTimeS != null "> and e.start_time_S = #{startTimeS}</if>
            <if test="endTimeS != null "> and e.end_time_S = #{endTimeS}</if>
            <if test="daysL != null "> and e.days_L = #{daysL}</if>
            <if test="daysS != null "> and e.days_S = #{daysS}</if>
            <if test="diffCoefficient != null  and diffCoefficient != ''"> and e.diff_coefficient = #{diffCoefficient}</if>
            <if test="diffCoefficientStandard != null  and diffCoefficientStandard != ''"> and e.diff_coefficient_standard = #{diffCoefficientStandard}</if>
        </where>
    </select>
    
    <select id="selectTEvaluateUnitById" parameterType="Integer" resultMap="TEvaluateUnitResult">
        <include refid="selectTEvaluateUnitVo"/>
        where e.id = #{id}
    </select>
        
