<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.physical.mapper.TCoalUncoverMapper">
    
    <resultMap type="TCoalUncover" id="TCoalUncoverResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="status"    column="status"    />
        <result property="holesize"    column="holesize"    />
        <result property="governRange"    column="govern_range"    />
        <result property="coalReserves"    column="coal_reserves"    />
        <result property="gasContentOriginal"    column="gas_content_original"    />
        <result property="targetTotal"    column="target_total"    />
        <result property="quantityTotal"    column="quantity_total"    />
        <result property="predictfinishDate"    column="predictfinish_date"    />
    </resultMap>

    <sql id="selectTCoalUncoverVo">
        select id, name, status, holesize, govern_range, coal_reserves, gas_content_original, target_total, quantity_total, predictfinish_date from t_coal_uncover
    </sql>

    <select id="selectTCoalUncoverList" parameterType="TCoalUncover" resultMap="TCoalUncoverResult">
        <include refid="selectTCoalUncoverVo"/>
        <where>
            <if test="id != null and id != 0"> and id = #{id}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="holesize != null "> and holesize = #{holesize}</if>
            <if test="governRange != null  and governRange != ''"> and govern_range = #{governRange}</if>
            <if test="coalReserves != null "> and coal_reserves = #{coalReserves}</if>
            <if test="gasContentOriginal != null  and gasContentOriginal != ''"> and gas_content_original = #{gasContentOriginal}</if>
            <if test="targetTotal != null "> and target_total = #{targetTotal}</if>
            <if test="quantityTotal != null "> and quantity_total = #{quantityTotal}</if>
            <if test="predictfinishDate != null "> and predictfinish_date = #{predictfinishDate}</if>
        </where>
    </select>
    
    <select id="selectTCoalUncoverById" parameterType="Integer" resultMap="TCoalUncoverResult">
        <include refid="selectTCoalUncoverVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertTCoalUncover" parameterType="TCoalUncover" useGeneratedKeys="true" keyProperty="id">
        insert into t_coal_uncover
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="status != null">status,</if>
            <if test="holesize != null">holesize,</if>
            <if test="governRange != null">govern_range,</if>
            <if test="coalReserves != null">coal_reserves,</if>
            <if test="gasContentOriginal != null">gas_content_original,</if>
            <if test="targetTotal != null">target_total,</if>
            <if test="quantityTotal != null">quantity_total,</if>
            <if test="predictfinishDate != null">predictfinish_date,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="status != null">#{status},</if>
            <if test="holesize != null">#{holesize},</if>
            <if test="governRange != null">#{governRange},</if>
            <if test="coalReserves != null">#{coalReserves},</if>
            <if test="gasContentOriginal != null">#{gasContentOriginal},</if>
            <if test="targetTotal != null">#{targetTotal},</if>
            <if test="quantityTotal != null">#{quantityTotal},</if>
            <if test="predictfinishDate != null">#{predictfinishDate},</if>
         </trim>
    </insert>

    <update id="updateTCoalUncover" parameterType="TCoalUncover">
        update t_coal_uncover
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="status != null">status = #{status},</if>
            <if test="holesize != null">holesize = #{holesize},</if>
            <if test="governRange != null">govern_range = #{governRange},</if>
            <if test="coalReserves != null">coal_reserves = #{coalReserves},</if>
            <if test="gasContentOriginal != null">gas_content_original = #{gasContentOriginal},</if>
            <if test="targetTotal != null">target_total = #{targetTotal},</if>
            <if test="quantityTotal != null">quantity_total = #{quantityTotal},</if>
            <if test="predictfinishDate != null">predictfinish_date = #{predictfinishDate},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTCoalUncoverById" parameterType="Integer">
        delete from t_coal_uncover where id = #{id}
    </delete>

    <delete id="deleteTCoalUncoverByIds" parameterType="String">
        delete from t_coal_uncover where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>