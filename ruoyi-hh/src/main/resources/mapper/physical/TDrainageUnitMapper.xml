            <if test="Y4 != null "> and d.Y4 = #{Y4}</if>
            <if test="Z4 != null "> and d.Z4 = #{Z4}</if>
        </where>
    </select>

    <select id="selectTDrainageUnitById" parameterType="java.lang.Integer" resultMap="TDrainageUnitResult">
