    <sql id="selectTDrainageUnitVo">
       select d.id, d.unit_name, d.evaluation_unit_id,e.evaluate_unit_name,d.drainage_unit_type_id,d.roadway_id,r.roadway as roadwayName,du.type_name as drainageUnitTypeName, d.workface_id,w.workface_name, d.start_date,
       d.length, d.wide, d.coal_reserves, d.gas_content_original, d.gas_total_reserves, d.borehole_length_total,
       d.bore_diameter, d.bore_diameter_collect, d.X1, d.Y1, d.Z1, d.X2, d.Y2, d.Z2, d.X3, d.Y3, d.Z3, d.X4, d.Y4, d.Z4, d.create_by, d.create_time, d.update_by, d.update_time,
       d.remark from t_drainage_unit d
       left join t_drainageunit_type du on d.drainage_unit_type_id=du.id
       left join t_working_face w on d.workface_id=w.id
       left join t_evaluate_unit e on d.evaluation_unit_id=e.id
       left join t_roadway r on d.roadway_id = r.id
    </sql>

    <select id="selectTDrainageUnitList" parameterType="TDrainageUnit" resultMap="TDrainageUnitResult">
        <include refid="selectTDrainageUnitVo"/>
        <where>
            <if test="id!=null and id!=0">and d.id=#{id}</if>
            <if test="unitName != null  and unitName != ''"> and d.unit_name like concat('%', #{unitName}, '%')</if>
            <if test="evaluationUnitId != null "> and d.evaluation_unit_id = #{evaluationUnitId}</if>
            <if test="drainageUnitTypeId != null "> and d.drainage_unit_type_id = #{drainageUnitTypeId}</if>
