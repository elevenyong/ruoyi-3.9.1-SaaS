    <!--查询抽采单元累计流量-->
    <select id="getDrainageUnitTotal" resultType="com.ruoyi.hh.simulate.domain.DrainageUnitTool">
        SELECT w.workface_name,w.workface_serial,d.unit_name,dt.type_name,m.measuring_point_name,i.sensor_name,
        t.id AS sensortype,t.kind,ROUND(SUM(sd.avg_value)/COUNT(sd.avg_value),2) AS avgvalue,ROUND(SUM(sd.sum_value),2) AS sumvalue
        from t_sensor_data sd
        LEFT JOIN t_sensor_info i ON i.id=sd.sensorInfo_id
        LEFT JOIN t_sensor_type t ON i.sensor_type_id=t.id
        LEFT JOIN t_measuring_point m ON i.measure_point_id=m.id
        LEFT JOIN t_drainage_unit d ON m.drainage_unit_id=d.id
        LEFT JOIN t_working_face w ON d.workface_id=w.id
        LEFT JOIN t_drainageunit_type dt ON d.drainage_unit_type_id=dt.id
        WHERE t.id IN (1,2) and w.id= #{workfaceId}
        GROUP BY d.unit_name,t.kind
    </select>
