<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.physical.mapper.TGroundElevationMapper">

    <resultMap type="TGroundElevation" id="TGroundElevationResult">
        <result property="id" column="id"/>
        <result property="workfaceId" column="workface_id"/>
        <result property="x" column="x"/>
        <result property="y" column="y"/>
        <result property="z" column="z"/>
        <result property="description" column="description"/>
    </resultMap>

    <sql id="selectTGroundElevationVo">
        select id,
               workface_id,
               x,
               y,
               z,
               description
        from t_ground_elevation
    </sql>

    <select id="selectTGroundElevationList" parameterType="TGroundElevation" resultMap="TGroundElevationResult">
        <include refid="selectTGroundElevationVo"/>
        <where>
            <if test="id != null and id != 0"> and id = #{id}</if>
            <if test="workfaceId != null and workfaceId != 0 ">and workface_id = #{workfaceId}</if>
            <if test="x != null ">and x = #{x}</if>
            <if test="y != null ">and y = #{y}</if>
            <if test="z != null ">and z = #{z}</if>
            <if test="description != null and description != ''">and "description" = #{description}</if>
        </where>
    </select>

    <select id="selectTGroundElevationById" parameterType="Integer" resultMap="TGroundElevationResult">
        <include refid="selectTGroundElevationVo"/>
        where id = #{id}
    </select>

    <insert id="insertTGroundElevation" parameterType="TGroundElevation" useGeneratedKeys="true" keyProperty="id">
        insert into t_ground_elevation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="workfaceId != null and workfaceId != 0">workface_id,</if>
            <if test="x != null">x,</if>
            <if test="y != null">y,</if>
            <if test="z != null">z,</if>
            <if test="description != null">"description"</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="workfaceId != null and workfaceId != 0">#{workfaceId},</if>
            <if test="x != null">#{x},</if>
            <if test="y != null">#{y},</if>
            <if test="z != null">#{z},</if>
            <if test="description != null">#{description}</if>
        </trim>
    </insert>

    <update id="updateTGroundElevation" parameterType="TGroundElevation">
        update t_ground_elevation
        <trim prefix="SET" suffixOverrides=",">
            <if test="workfaceId != null and workfaceId != 0">workface_id = #{workfaceId},</if>
            <if test="x != null">x = #{x},</if>
            <if test="y != null">y = #{y},</if>
            <if test="z != null">z = #{z},</if>
            <if test="description != null">"description" = #{description}</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTGroundElevationById" parameterType="Integer">
        delete
        from t_ground_elevation
        where id = #{id}
    </delete>

    <delete id="deleteTGroundElevationByWorkfaceId" parameterType="Integer">
        delete
        from t_ground_elevation
        where workface_id = #{workfaceId}
    </delete>

    <delete id="deleteTGroundElevationByIds" parameterType="String">
        delete from t_ground_elevation where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!--根据工作面ID查询地面高程点列表-->
    <select id="getByWorkfaceId" resultType="com.ruoyi.hh.physical.domain.TGroundElevation">
        select *
        from t_ground_elevation
        where workface_id = #{workfaceId}
    </select>
</mapper>
