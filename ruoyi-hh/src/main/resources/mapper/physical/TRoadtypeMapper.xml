<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.physical.mapper.TRoadtypeMapper">

    <resultMap type="TRoadtype" id="TRoadtypeResult">
        <result property="id"    column="id"    />
        <result property="roadwayType"    column="roadway_type"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTRoadtypeVo">
        select id, roadway_type, create_by, create_time, update_by, update_time, remark from t_roadtype
    </sql>

    <select id="selectTRoadtypeList" parameterType="TRoadtype" resultMap="TRoadtypeResult">
        <include refid="selectTRoadtypeVo"/>
        <where>
            <if test="id!=null and id!=0">and id=#{id}</if>
            <if test="roadwayType != null  and roadwayType != ''"> and roadway_type = #{roadwayType}</if>
        </where>
    </select>

    <select id="selectTRoadtypeById" parameterType="Integer" resultMap="TRoadtypeResult">
        <include refid="selectTRoadtypeVo"/>
        where Id = #{id}
    </select>

    <insert id="insertTRoadtype" parameterType="TRoadtype" useGeneratedKeys="true" keyProperty="id">
        insert into t_roadtype
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="roadwayType != null">roadway_type,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="roadwayType != null">#{roadwayType},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTRoadtype" parameterType="TRoadtype">
        update t_roadtype
        <trim prefix="SET" suffixOverrides=",">
            <if test="roadwayType != null">roadway_type = #{roadwayType},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where Id = #{id}
    </update>

    <delete id="deleteTRoadtypeById" parameterType="java.lang.Integer">
        delete from t_roadtype where id = #{id}
    </delete>

    <delete id="deleteTRoadtypeByIds" parameterType="java.util.List">
        delete from t_roadtype where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="getPageList" resultType="com.ruoyi.hh.physical.domain.TRoadtype">
        <include refid="selectTRoadtypeVo"/>
    </select>
    <!--根据巷道类型查询类型ID-->
    <select id="getIdByType" resultType="java.lang.Integer" parameterType="string">
        select id from t_roadtype where roadway_type = #{roadwayType}
    </select>
</mapper>