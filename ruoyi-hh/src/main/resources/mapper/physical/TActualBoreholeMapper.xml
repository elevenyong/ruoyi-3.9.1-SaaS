            <if test="exceptionDuringDrilling != null">exception_during_drilling = #{exceptionDuringDrilling},</if>
            <if test="holesealTypeId != 0">holeseal_type_id = #{holesealTypeId},</if>
            <if test="downTubeTimeStart != null">down_tube_time_start = #{downTubeTimeStart},</if>
            <if test="downTubeTimeEnd != null">down_tube_time_end = #{downTubeTimeEnd},</if>
            <if test="tubeLength != null">tube_length = #{tubeLength},</if>
            <if test="solidPipelineLength != null">solid_pipeline_length = #{solidPipelineLength},</if>
            <if test="sievePipelineLength != null">sieve_pipeline_length = #{sievePipelineLength},</if>
            <if test="holeSealingSpecification != null">hole_sealing_specification = #{holeSealingSpecification},</if>
            <if test="gasChecker != null">gas_checker = #{gasChecker},</if>
            <if test="personConstruction != null">person_construction = #{personConstruction},</if>
            <if test="chargehand != null">chargehand = #{chargehand},</if>
            <if test="validFootage != 0">valid_footage = #{validFootage},</if>
            <if test="personChecking != null">person_checking = #{personChecking},</if>
            <if test="checkingDate != null">checking_date = #{checkingDate},</if>
            <if test="sign != null">sign = #{sign},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where Id = #{id}
    </update>

    <delete id="deleteTActualBoreholeById" parameterType="java.lang.Integer">
        delete
        from t_actual_borehole
        where id = #{id}
    </delete>

    <delete id="deleteTActualBoreholeByIds" parameterType="java.util.List">
        delete from t_actual_borehole where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>


    <select id="getPageList" resultType="com.ruoyi.hh.physical.domain.TActualBorehole">
        select d.*,
               r.roadway,
               r.id,
               c.borehole_category,
               p.purpose_borehole,
               n.navigation_point_name,
               z.zone_name,
               m.measuring_point_name
        from t_actual_borehole d
                 LEFT JOIN t_roadway r ON d.roadway_id = r.id
                 LEFT JOIN t_borehole_category c ON d.borehole_category_id = c.Id
                 LEFT JOIN t_navigation_point n ON d.navigation_point_id = n.id
                 LEFT JOIN t_purpose_borehole p ON d.purpose_boreholeId = p.Id
                 LEFT JOIN t_roadway_zone z ON d.roadway_zone_id = z.Id
                 LEFT JOIN t_measuring_point m ON d.measure_point_id = m.id
    </select>

    <!--根据组名查询列表-->
    <select id="getByGroupNo" resultType="com.ruoyi.hh.physical.domain.TActualBorehole" parameterType="int">
        select *
        from t_actual_borehole
        where group_no = #{groupNo}
    </select>

    <!--钻孔原始验收单-->
    <select id="getAcceptanceCertificate" resultType="com.ruoyi.hh.physical.domain.TActualBorehole">
        SELECT r.roadway,n.navigation_point_name,d.aperture AS desaperture,d.depth_1st_coal_seam_start AS
        desCoalSeamStart,
        d.azimuth_angle AS desazimuthAngle,d.inclination_angle AS desinclinationAngle,
        a.* from t_actual_borehole a
        LEFT JOIN t_navigation_point n ON n.id=a.navigation_point_id
        LEFT JOIN t_roadway r ON r.id=a.roadway_id
        LEFT JOIN t_designed_borehole d ON
        CONCAT(a.roadway_id,a.group_no,a.borehole_no)=CONCAT(d.roadway_id,d.group_no,d.borehole_no)
        WHERE 1=1
        <if test="roadwayId!=null">
            AND a.roadway_id = #{roadwayId}
        </if>
        <if test="groupNo!=null">
            AND a.group_no = #{groupNo}
        </if>
        <if test="boreholeNo!=null">and a.borehole_no IN
            <foreach collection="boreholeNo" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="startDate!=null and endDate!=null">
            AND a.checking_date BETWEEN #{startDate} and #{endDate}
        </if>
    </select>

    <!--根据巷道ID查询实钻ID-->
    <select id="getIdsByRoadWayId" parameterType="java.lang.Integer" resultType="java.lang.Integer">
        select id
        from t_actual_borehole
        where roadway_id = #{roadwayId}
    </select>

    <!--根据区段ID查询实钻ID列表-->
    <select id="getIdsRoadWayZoneId" parameterType="java.lang.Integer" resultType="java.lang.Integer">
        select id
        from t_actual_borehole
        where roadway_zone_id = #{roadwayZoneId}
    </select>

    <!--根据导线点ID查询实钻ID列表-->
    <select id="getIdsNavigationPointId" parameterType="java.lang.Integer" resultType="java.lang.Integer">
        select id
        from t_actual_borehole
        where navigation_point_id = #{navigationPointId}
    </select>

    <!--根据组号解绑钻孔和测点的关系-->
    <update id="unbundleByMeasurePointId" parameterType="java.lang.Integer">
        update t_actual_borehole
        set measure_point_id =null
        where group_no =#{groupNo}
    </update>

    <!--根据组号绑定钻孔和测点的关系-->
    <select id="getBoreholeInfo" resultType="com.ruoyi.hh.business.domain.TGasDrillingStandingBook">
        SELECT r.roadway,a.group_no,a.borehole_no,p.purpose_borehole,d.azimuth_angle AS DesAzimuthAngle,a.azimuth_angle
        AS ActAzimuthAngle,d.inclination_angle AS DesInclinationAngle,
        a.inclination_angle AS ActInclinationAngle,d.depth_1st_rock_seam_start AS
        DesDepth1stCoalSeamStart,a.depth_1st_coal_seam_start AS ActDepth1stCoalSeamStart,
        d.borehole_length AS DesBoreholeLength,a.borehole_length AS ActBoreholeLength,a.depth_1st_rock_seam_start AS
        rockseamlength,n.navigation_point_name,a.distance_to_navigation_point,h.hole_seal_type,
        (af.punching_paragraph2-punching_paragraph1)AS
        FlushingLength,af.actual_coal_amount_flushed,af.completion_ratio_flushed_coal
        from t_actual_borehole a
        LEFT JOIN t_designed_borehole d ON
        CONCAT(a.roadway_id,a.group_no,a.borehole_no) =CONCAT(d.roadway_id,d.group_no,d.borehole_no)
        LEFT JOIN t_actual_flushing af ON
        a.id=af.Id
        LEFT JOIN t_navigation_point n ON
        a.navigation_point_id =n.id
        LEFT JOIN t_sealing_grouting s ON
        a.id=s.BoreholeId
        LEFT JOIN t_holeseal_type h ON
        h.Id = s.holeseal_type_id
        LEFT JOIN t_roadway r ON
        r.Id = a.roadway_id
        LEFT JOIN t_purpose_borehole p ON
        p.Id = a.purpose_boreholeId
        WHERE 1=1
        <if test="roadWayId!=null">AND a.roadway_id=#{roadwayId}</if>
        <if test="groupNo!=null">AND a.GroupId IN
            <foreach collection="groupNo" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="purposeBoreholeId!=null">AND a.purpose_boreholeId IN
            <foreach collection="purposeBoreholeId" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="boreholeNo!=null">AND a.borehole_no IN
            <foreach collection="boreholeNo" item="item" index="index" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="startDate!=null">
            AND
            a.checking_date BETWEEN #{startDate} AND #{endDate}
        </if>

    </select>


    <!--根据巷道ID删除实钻信息-->
    <update id="bundleByMeasurePointId" parameterType="java.lang.Integer">
        update t_actual_borehole
        set measure_point_id ={measurePointId}
        where group_no =#{groupId}
    </update>
    <delete id="delByRoadWayId" parameterType="int">
        delete
        from t_actual_borehole
        where roadway_id = #{roadwayId}
    </delete>

    <!--根据区段ID删除实际钻孔信息-->
    <delete id="delByRoadWayIds" parameterType="java.util.List">
        delete from t_actual_borehole where roadway_id in
        <foreach item="roadwayIds" collection="list" open="(" separator="," close=")">
            #{roadwayIds}
        </foreach>
    </delete>
    <delete id="delByRoadwayZoneId" parameterType="int">
        delete
        from t_actual_borehole
        where roadway_zone_id = #{roadwayZoneId}
    </delete>
    <!--根据导线点ID删除实际钻孔信息-->
    <delete id="delByRoadwayZoneIds" parameterType="java.util.List">
        delete from t_actual_borehole where roadway_zone_id in
        <foreach item="roadwayZoneIds" collection="list" open="(" separator="," close=")">
            #{roadwayZoneIds}
        </foreach>
    </delete>
    <delete id="delByNavigationPointId" parameterType="int">
        delete
        from t_actual_borehole
        where navigation_point_id = #{navigationPointId}
    </delete>

    <!--查询实钻信息-->
    <delete id="delNavigationPointIds" parameterType="java.util.List">
        delete from t_actual_borehole where navigation_point_id in
        <foreach item="navigationPointIds" collection="list" open="(" separator="," close=")">
            #{navigationPointIds}
        </foreach>
    </delete>
    <!--根据巷道ID，组号和孔号查询钻孔ID-->
    <select id="getId" resultType="java.lang.Integer">
        select id
        from t_actual_borehole
        where roadway_id = #{roadwayId}
          and group_no = #{groupNo}
          and borehole_no = #{boreholeNO}
    </select>

    <!--根据巷道ID查询实钻信息-->
    <select id="getByRoadWayId" resultType="com.ruoyi.hh.physical.domain.TActualBorehole">
        select *
        from t_actual_borehole
        where roadway_id = #{roadwayId}
    </select>

    <select id="getGroupNosByRoadwayId" resultType="java.lang.Integer">
        select group_no
        from t_actual_borehole
        where roadway_id = #{roadwayId}
        group by group_no
    </select>

    <!--根据巷道ID和组号查孔号-->
    <select id="getBoreholenoByRoadwayIdAndGroupNo" resultType="java.lang.Integer">
        select borehole_no
        from t_actual_borehole
        where roadway_id = #{roadwayId}
          and group_no = #{groupNo}
    </select>
    <!--查询孔号和自增序号-->
    <select id="getIdAndBoreholeNo" resultType="com.ruoyi.hh.business.domain.TSealingGrouting">
        select id AS boreholeid, borehole_no
        from t_actual_borehole
        where roadway_id = #{roadwayId}
          and group_no = #{groupNo}
    </select>
    <!--根据巷道名称，组号，孔号查询实钻ID-->
    <select id="getIdByRoadWayAndGroupIdBoreholeno" resultType="Integer">
        select id
        from t_actual_borehole
        where group_no = #{groupNo}
          and borehole_no = #{boreholeNo}
          and roadway_id = (SELECT id from t_roadway where roadway = #{roadway})
    </select>

    <select id="selectTActualBoreholeWithException" resultType="com.ruoyi.hh.demo.domain.TActualBorholeException">
        SELECT t_actual_borehole.id                        id,
               t_actual_borehole.roadway_id                 roadWayId,
               t_roadway.roadway                           roadWayName,
               t_actual_borehole.group_no                   groupNo,
               t_actual_borehole.borehole_no               boreholeNo,
               t_actual_borehole.navigation_point_id        navPointId,
               t_navigation_point.navigation_point_name    navPointName,
               t_navigation_point.X                        x,
               t_navigation_point.Y                        y,
               t_navigation_point.Z                        z,
               t_actual_borehole.exception_during_drilling exceptions
        FROM t_actual_borehole,
             t_navigation_point,
             t_roadway
        WHERE t_actual_borehole.navigation_point_id = t_navigation_point.id
          AND t_actual_borehole.roadway_id = t_roadway.id
          AND exception_during_drilling != "" AND exception_during_drilling != "无"
    </select>

    <!--根据工作面查询实钻信息-->
    <select id="getByWorkfaceId" resultType="com.ruoyi.hh.physical.domain.TActualBorehole">
        select CONCAT(a.group_no,"-",a.borehole_no) AS holeNo,r.roadway,a.inclination_angle,a.azimuth_angle,
        (a.depth_1st_coal_seam_end-a.depth_1st_coal_seam_start+a.depth_2st_coal_seam_end-a.depth_2st_coal_seam_start) as coalholelength,
        a.borehole_length
        from t_actual_borehole a LEFT JOIN t_roadway r
        ON a.roadway_id =r.id
        LEFT JOIN t_working_face w ON r.workfaceId =w.id
        WHERE w.id=#{workfaceId}
    </select>

    <!--达标评判之实测瓦斯含量压力情况-->
    <select id="getGasContentPressureByWorkfaceid" parameterType="java.lang.Integer" resultType="com.ruoyi.hh.physical.domain.TActualBorehole">
        SELECT CONCAT(a.group_no,"-",a.borehole_no) AS holeNo,g.sampling_prot,g.gas_content,g.gas_pressure
        from t_actual_borehole a
        LEFT JOIN t_gas_content_pressure g
        ON g.boreholeid=a.id
        LEFT JOIN t_roadway r
        ON a.roadway_id=r.id
        LEFT JOIN t_working_face w
        ON r.workfaceId=w.id
        where w.id=#{workfaceId}
    </select>
</mapper>
