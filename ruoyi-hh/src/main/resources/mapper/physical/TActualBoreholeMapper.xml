    <sql id="selectTActualBoreholeVo">
        select d.*,
               r.roadway,
               f.shift_info,
               c.borehole_category,
               p.purpose_borehole,
               n.navigation_point_name,
               h.hole_seal_type,
               m.measuring_point_name,
               z.zone_name
        from t_actual_borehole d
                 LEFT JOIN t_roadway r ON d.roadway_id = r.id
                 LEFT JOIN t_borehole_category c ON d.borehole_category_id = c.Id
                 LEFT JOIN t_navigation_point n ON d.navigation_point_id = n.id
                 LEFT JOIN t_purpose_borehole p ON d.purpose_borehole_id = p.Id
                 LEFT JOIN t_measuring_point m ON d.measure_point_id = m.id
                 LEFT JOIN t_roadway_zone z ON z.id = d.roadway_zone_id
                 LEFT JOIN t_shiftinfo f ON f.id = d.shift_id
                 LEFT JOIN t_holeseal_type h ON h.id = d.holeseal_type_id


    </sql>

