            <if test="roadwayId != null and roadwayId != 0">roadway_id = #{roadwayId},</if>
            <if test="groupNo != null">group_no = #{groupNo},</if>
            <if test="boreholeNo != null">borehole_no = #{boreholeNo},</if>
            <if test="boreholeCode != null">borehole_code = #{boreholeCode},</if>
            <if test="categoryCode != null">category_code = #{categoryCode},</if>
            <if test="navigationPointId != null and navigationPointId != 0">navigation_point_id = #{navigationPointId},</if>
            <if test="distanceToNavigationPoint != null">distance_to_navigation_point = #{distanceToNavigationPoint},</if>
            <if test="directionToNavigation != null">direction_to_navigation = #{directionToNavigation},</if>
            <if test="distanceToCentrallineTunnel != null">distance_to_centralline_tunnel = #{distanceToCentrallineTunnel},</if>
            <if test="topOrBottom != null">top_or_bottom = #{topOrBottom},</if>
            <if test="aperture != null">aperture = #{aperture},</if>
            <if test="drillPipeLength != null">drill_pipe_length = #{drillPipeLength},</if>
            <if test="endAzimuth != null">end_azimuth = #{endAzimuth},</if>
            <if test="endTilt != null">end_tilt = #{endTilt},</if>
            <if test="desParameterId != null">des_parameter_id = #{desParameterId},</if>
            <if test="sign != null">sign = #{sign},</if>
            <if test="holeAltitude != null">hole_altitude = #{holeAltitude},</if>
        </trim>
