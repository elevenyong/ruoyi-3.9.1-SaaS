         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="roadwayId != null and roadwayId != 0">#{roadwayId},</if>
            <if test="groupNo != null">#{groupNo},</if>
            <if test="boreholeNo != null">#{boreholeNo},</if>
            <if test="boreholeCode != null">#{boreholeCode},</if>
            <if test="categoryCode != null">#{categoryCode},</if>
            <if test="navigationPointId != null and navigationPointId != 0">#{navigationPointId},</if>
            <if test="distanceToNavigationPoint != null">#{distanceToNavigationPoint},</if>
            <if test="directionToNavigation != null">#{directionToNavigation},</if>
            <if test="distanceToCentrallineTunnel != null">#{distanceToCentrallineTunnel},</if>
