    <sql id="selectTDesignedDirectionalBoreholeVo">
        select id, roadway_id, group_no, borehole_no, borehole_code,category_code, navigation_point_id, distance_to_navigation_point, direction_to_navigation, distance_to_centralline_tunnel, top_or_bottom, aperture, drill_pipe_length, end_azimuth, end_tilt,des_parameter_id,sign,hole_altitude from t_des_directional_borehole
    </sql>

    <select id="selectTDesignedDirectionalBoreholeList" parameterType="TDesignedDirectionalBorehole" resultMap="TDesignedDirectionalBoreholeResult">
        <include refid="selectTDesignedDirectionalBoreholeVo"/>
        <where>
            <if test="id != null and id != 0"> and id = #{id}</if>
            <if test="roadwayId != null and roadwayId!=0"> and roadway_id = #{roadwayId}</if>
            <if test="groupNo != null  and groupNo != ''"> and group_no = #{groupNo}</if>
            <if test="boreholeNo != null and boreholeNo !=0"> and borehole_no = #{boreholeNo}</if>
            <if test="boreholeCode != null  and boreholeCode != ''"> and borehole_code = #{boreholeCode}</if>
            <if test="categoryCode != null and categoryCode !=0"> and category_code = #{categoryCode}</if>
            <if test="navigationPointId != null and navigationPointId !=0"> and navigation_point_id = #{navigationPointId}</if>
            <if test="distanceToNavigationPoint != null and distanceToNavigationPoint !=0"> and distance_to_navigation_point = #{distanceToNavigationPoint}</if>
            <if test="directionToNavigation != null  and directionToNavigation != ''"> and direction_to_navigation = #{directionToNavigation}</if>
            <if test="distanceToCentrallineTunnel != null and distanceToCentrallineTunnel !=0"> and distance_to_centralline_tunnel = #{distanceToCentrallineTunnel}</if>
            <if test="topOrBottom != null "> and top_or_bottom = #{topOrBottom}</if>
            <if test="aperture != null "> and aperture = #{aperture}</if>
            <if test="drillPipeLength != null and drillPipeLength !=0"> and drill_pipe_length = #{drillPipeLength}</if>
            <if test="endAzimuth != null and endAzimuth != 0"> and end_azimuth = #{endAzimuth}</if>
            <if test="endTilt != null and endTilt !=0"> and end_tilt = #{endTilt}</if>
            <if test="desParameterId != null and desParameterId !=0"> and des_parameter_id = #{desParameterId}</if>
            <if test="sign != null"> and sign >= #{sign}</if>
            <if test="holeAltitude != null and holeAltitude !=0"> and hole_altitude = #{holeAltitude}</if>
        </where>
    </select>

    <select id="selectTDesignedDirectionalBoreholeById" parameterType="Integer" resultMap="TDesignedDirectionalBoreholeResult">
        <include refid="selectTDesignedDirectionalBoreholeVo"/>
        where id = #{id}
    </select>

    <insert id="insertTDesignedDirectionalBorehole" parameterType="TDesignedDirectionalBorehole" useGeneratedKeys="true" keyProperty="id">
        insert into t_des_directional_borehole
        <trim prefix="(" suffix=")" suffixOverrides=",">
