    <delete id="deleteTDesignedDirectionalBoreholeById" parameterType="Integer">
        delete from t_des_directional_borehole where id = #{id}
    </delete>

    <delete id="deleteTDesignedDirectionalBoreholeByIds" parameterType="String">
        delete from t_des_directional_borehole where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!--更改设计钻孔为确定-->
