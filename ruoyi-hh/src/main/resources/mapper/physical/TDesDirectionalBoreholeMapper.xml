            <if test="groupNo != null">group_no,</if>
            <if test="boreholeNo != null">borehole_no,</if>
            <if test="boreholeCode != null">borehole_code,</if>
            <if test="categoryCode != null">category_code,</if>
            <if test="navigationPointId != null and navigationPointId != 0">navigation_point_id,</if>
            <if test="distanceToNavigationPoint != null">distance_to_navigation_point,</if>
            <if test="directionToNavigation != null">direction_to_navigation,</if>
            <if test="distanceToCentrallineTunnel != null">distance_to_centralline_tunnel,</if>
