        <result property="distanceToCentrallineTunnel"    column="distance_to_centralline_tunnel"    />
        <result property="topOrBottom"    column="top_or_bottom"    />
        <result property="aperture"    column="aperture"    />
        <result property="drillPipeLength"    column="drill_pipe_length"    />
        <result property="endAzimuth"    column="end_azimuth"    />
