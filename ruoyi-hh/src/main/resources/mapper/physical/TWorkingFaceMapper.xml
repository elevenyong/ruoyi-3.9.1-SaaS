<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.physical.mapper.TWorkingFaceMapper">

    <resultMap type="TWorkingFace" id="TWorkingFaceResult">
        <result property="id"    column="id"    />
        <result property="workfaceName"    column="workface_name"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="workfaceSerial"    column="workface_serial"    />
        <result property="miningAreaId"    column="mining_area_id"    />
        <result property="coalId"    column="coal_id"    />
        <result property="towardsLength"    column="towards_length"    />
        <result property="cutLength"    column="cut_length"    />
        <result property="coalReserves"    column="coal_reserves"    />
        <result property="gasTotalreserves"    column="gas_totalreserves"    />
        <result property="gasContentOriginal"    column="gas_content_original"    />
        <result property="gasAmountReachStandard"    column="gas_amount_reach_standard"    />
        <result property="reachStandardGasRemaining"    column="reach_standard_gas_remaining"    />
        <result property="extractionRadius"    column="extraction_radius"    />
        <result property="beginDrainageDate"    column="begin_drainage_date"    />
    </resultMap>

    <sql id="selectTWorkingFaceVo">
        select w.id, m.mining_area, w.workface_name, w.workface_serial, w.mining_area_id, w.coal_id, w.towards_length, w.cut_length, w.coal_reserves,
        w.gas_totalreserves, w.gas_content_original, w.gas_amount_reach_standard, w.reach_standard_gas_remaining,w.extraction_radius,
        w.begin_drainage_date, w.create_time, w.create_by, w.update_time, w.update_by, w.remark from t_working_face w
				LEFT JOIN t_mining_area m ON w.mining_area_id=m.id
    </sql>

    <select id="selectTWorkingFaceList" parameterType="TWorkingFace" resultMap="TWorkingFaceResult">
        <include refid="selectTWorkingFaceVo"/>
        <where>
            <if test="id!=null and id!=0">and w.d.id=#{id}</if>
            <if test="workfaceName != null  and workfaceName != ''"> and w.workface_name like concat('%', #{workfaceName}, '%')</if>
            <if test="workfaceSerial != null  and workfaceSerial != ''"> and w.workface_serial = #{workfaceSerial}</if>
            <if test="miningAreaId != null and miningAreaId != 0 "> and w.mining_area_id = #{miningAreaId}</if>
            <if test="coalId != null and coalId != 0 "> and w.coal_id = #{coalId}</if>
            <if test="towardsLength != null "> and w.towards_length = #{towardsLength}</if>
            <if test="cutLength != null "> and w.cut_length = #{cutLength}</if>
            <if test="coalReserves != null "> and w.coal_reserves = #{coalReserves}</if>
            <if test="gasTotalreserves != null  and gasTotalreserves != ''"> and w.gas_totalreserves = #{gasTotalreserves}</if>
            <if test="gasContentOriginal != null "> and w.gas_content_original = #{gasContentOriginal}</if>
            <if test="gasAmountReachStandard != null "> and w.gas_amount_reach_standard = #{gasAmountReachStandard}</if>
            <if test="reachStandardGasRemaining != null "> and w.reach_standard_gas_remaining = #{reachStandardGasRemaining}</if>
            <if test="extractionRadius != null "> and w.extraction_radius = #{extractionRadius}</if>
            <if test="beginDrainageDate != null "> and w.begin_drainage_date = #{beginDrainageDate}</if>
        </where>
    </select>

    <select id="selectTWorkingFaceById" parameterType="Integer" resultMap="TWorkingFaceResult">
        <include refid="selectTWorkingFaceVo"/>
        where w.id = #{id}
    </select>

    <insert id="insertTWorkingFace" parameterType="TWorkingFace" useGeneratedKeys="true" keyProperty="id">
        insert into t_working_face
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="workfaceName != null">workface_name,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="workfaceSerial != null">workface_serial,</if>
            <if test="miningAreaId != null and miningAreaId != 0">mining_area_id,</if>
            <if test="coalId != null and coalId != 0">coal_id,</if>
            <if test="towardsLength != null">towards_length,</if>
            <if test="cutLength != null">cut_length,</if>
            <if test="coalReserves != null">coal_reserves,</if>
            <if test="gasTotalreserves != null">gas_totalreserves,</if>
            <if test="gasContentOriginal != null">gas_content_original,</if>
            <if test="gasAmountReachStandard != null">gas_amount_reach_standard,</if>
            <if test="reachStandardGasRemaining != null">reach_standard_gas_remaining,</if>
            <if test="extractionRadius != null">extraction_radius,</if>
            <if test="beginDrainageDate != null">begin_drainage_date,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="workfaceName != null">#{workfaceName},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="workfaceSerial != null">#{workfaceSerial},</if>
            <if test="miningAreaId != null and miningAreaId != 0">#{miningAreaId},</if>
            <if test="coalId != null and coalId != 0">#{coalId},</if>
            <if test="towardsLength != null">#{towardsLength},</if>
            <if test="cutLength != null">#{cutLength},</if>
            <if test="coalReserves != null">#{coalReserves},</if>
            <if test="gasTotalreserves != null">#{gasTotalreserves},</if>
            <if test="gasContentOriginal != null">#{gasContentOriginal},</if>
            <if test="gasAmountReachStandard != null">#{gasAmountReachStandard},</if>
            <if test="reachStandardGasRemaining != null">#{reachStandardGasRemaining},</if>
            <if test="extractionRadius != null">#{extractionRadius},</if>
            <if test="beginDrainageDate != null">#{beginDrainageDate},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTWorkingFace" parameterType="TWorkingFace">
        update t_working_face
        <trim prefix="SET" suffixOverrides=",">
            <if test="workfaceName != null">workface_name = #{workfaceName},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="workfaceSerial != null">workface_serial = #{workfaceSerial},</if>
            <if test="miningAreaId != null and miningAreaId != 0">mining_area_id = #{miningAreaId},</if>
            <if test="coalId != null and coalId != 0">coal_id = #{coalId},</if>
            <if test="towardsLength != null">towards_length = #{towardsLength},</if>
            <if test="cutLength != null">cut_length = #{cutLength},</if>
            <if test="coalReserves != null">coal_reserves = #{coalReserves},</if>
            <if test="gasTotalreserves != null">gas_totalreserves = #{gasTotalreserves},</if>
            <if test="gasContentOriginal != null">gas_content_original = #{gasContentOriginal},</if>
            <if test="gasAmountReachStandard != null">gas_amount_reach_standard = #{gasAmountReachStandard},</if>
            <if test="reachStandardGasRemaining != null">reach_standard_gas_remaining = #{reachStandardGasRemaining},</if>
            <if test="extractionRadius != null">extraction_radius = #{extractionRadius},</if>
            <if test="beginDrainageDate != null">begin_drainage_date = #{beginDrainageDate},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where Id = #{id}
    </update>

    <delete id="deleteTWorkingFaceById" parameterType="Integer">
        delete from t_working_face where id = #{id}
    </delete>

    <delete id="deleteTWorkingFaceByIds" parameterType="java.util.List">
        delete from t_working_face where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <select id="getPageList" resultType="com.ruoyi.hh.physical.domain.TWorkingFace">
        <include refid="selectTWorkingFaceVo"/>
    </select>
    <!--根据工作面编号查询工作面-->
    <select id="getByWorkfaceSerial" resultType="java.lang.Integer">
        select id from t_working_face where mining_area_id =#{miningAreaId}
    </select>
    <!--根据工作面ID查询工作面名称-->
    <select id="getWorefaceNameById" parameterType="Integer" resultType="java.lang.String">
        select workface_name from t_working_face where id =#{id}
    </select>
    <!--工作面抽采动态-->
    <select id="getWorkfaceDrainageOperation" resultType="com.ruoyi.hh.physical.domain.TWorkingFace">
        SELECT
            w.id,
            w.workface_name,
            w.workface_serial,
            m.id AS miningAreaId,
            m.mining_area,
            c.id AS coalId,
            c.coal_serial,
            c.coal_reserves,
            w.towards_length,
            w.cut_length,
            w.gas_content_original,
            DATEDIFF(NOW(),begin_drainage_date) AS gooverdays,
            gas_amount_reach_standard,
            count( d.id ) AS countdrainageunit
        FROM
            t_working_face w
            LEFT JOIN t_coalinfo c ON w.coal_id = c.id
            LEFT JOIN t_mining_area m ON w.mining_area_id = m.id
            LEFT JOIN t_drainage_unit d ON d.workface_id = w.id
        GROUP BY
            w.id
    </select>
    <!--查询所有工作面ID-->
    <select id="getWorkFaceIds" resultType="java.lang.Integer">
        select id from t_working_face
    </select>
    <!--根据采区ID和工作面名称查询-->
    <select id="getByMinAreaIdAndWorkFaceName" resultType="com.ruoyi.hh.physical.domain.TWorkingFace">
        select * from t_working_face where workface_name=#{workfaceName} and mining_area_id=#{miningAreaId}
    </select>
    <!--根据ID查询-->
    <select id="getInfoById" resultType="com.ruoyi.hh.physical.domain.TWorkingFace">
        SELECT m.mining_area, w.*,
        c.id AS coalId,
        c.coal_serial,
        c.coal_reserves,
        DATEDIFF(NOW(),begin_drainage_date) AS gooverdays,
        gas_amount_reach_standard,
        count( d.id ) AS countdrainageunit
        from t_working_face w
        LEFT JOIN t_mining_area m ON w.mining_area_id=m.id
        LEFT JOIN t_coalinfo c ON w.coal_id = c.id
        LEFT JOIN t_drainage_unit d ON d.workface_id = w.id
        where w.id=#{workfaceId}
    </select>
</mapper>