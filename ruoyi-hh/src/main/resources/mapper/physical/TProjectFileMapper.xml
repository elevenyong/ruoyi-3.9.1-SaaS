<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.physical.mapper.TProjectFileMapper">

    <resultMap type="TProjectFile" id="TProjectFileResult">
        <result property="id" column="id"/>
        <result property="fileName" column="file_name"/>
        <result property="workfaceId" column="workface_id"/>
        <result property="filePath" column="file_path"/>
        <result property="fileSize" column="file_size"/>
        <result property="fileType" column="file_type"/>
        <result property="md5" column="md5"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectTProjectFileVo">
        select id,
               file_name,
               workface_id,
               file_path,
               file_size,
               file_type,
               md5,
               create_by,
               create_time,
               update_by,
               update_time,
               remark
        from t_project_file
    </sql>

    <select id="selectTProjectFileList" parameterType="TProjectFile" resultMap="TProjectFileResult">
        <include refid="selectTProjectFileVo"/>
        <where>
            <if test="fileName != null ">and file_name = #{fileName}</if>
            <if test="workfaceId != null">and workface_id = #{workfaceId}</if>
            <if test="filePath != null">and file_path = #{filePath}</if>
            <if test="fileSize != null ">and file_size = #{fileSize}</if>
            <if test="fileType != null ">and file_type = #{fileType}</if>
            <if test="md5 != null ">and md5 = #{md5}</if>
            <if test="remark != null ">and remark = #{remark}</if>
        </where>
    </select>

    <select id="selectTProjectFileById" parameterType="Integer" resultMap="TProjectFileResult">
        <include refid="selectTProjectFileVo"/>
        where id = #{id}
    </select>


    <insert id="insertTProjectFile" parameterType="TProjectFile" useGeneratedKeys="true" keyProperty="id">
        insert into t_project_file
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="fileName != null">file_name,</if>
            <if test="workfaceId != null">workface_id,</if>
            <if test="filePath != null">file_path,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="fileType != null">file_type,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="fileName != null">#{fileName},</if>
            <if test="workfaceId != null">#{workfaceId},</if>
            <if test="filePath != null">#{filePath},</if>
            <if test="fileSize != null">#{fileSize},</if>
            <if test="fileType != null">#{fileType},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTProjectFile" parameterType="TProjectFile">
        update t_project_file
        <trim prefix="SET" suffixOverrides=",">
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="workfaceId != null">workface_id = #{workfaceId},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="fileType != null">file_type = #{fileType},</if>
            <if test="md5 != null">md5 = #{md5},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTProjectFileById" parameterType="Integer">
        delete
        from t_project_file
        where id = #{id}
    </delete>

    <delete id="deleteTProjectFileByIds" parameterType="String">
        delete from t_project_file where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
