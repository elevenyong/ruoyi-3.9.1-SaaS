            <if test="id != null">#{id},</if>
            <if test="roadwayId != null and roadwayId != 0">#{roadwayId},</if>
            <if test="drainageUnitId != null and drainageUnitId != 0">#{drainageUnitId},</if>
            <if test="pipeTypeId != null and pipeTypeId != 0">#{pipeTypeId},</if>
            <if test="serial != null">#{serial},</if>
