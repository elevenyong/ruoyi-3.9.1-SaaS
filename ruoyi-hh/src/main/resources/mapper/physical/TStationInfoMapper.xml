    <!--更改测点安装位置所属的巷道-->
    <update id="updateRoadwayIdByLocal">
        update t_station_info set roadway_id =#{roadwayId} where measure_point_local in
        <foreach collection="measurePointLocals" item="item" index="index" open="(" separator="," close=")">
            #{item}
        </foreach>
    </update>
    <!--设置测点的位置逻辑信息-->
    <update id="setStationInfo">
        update t_station_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="roadwayId!=null and roadwayId!=0">roadway_id =#{roadwayId},</if>
            <if test="drainageUnitId != null and drainageUnitId != 0">drainage_unit_id = #{drainageUnitId},</if>
            <if test="pipeTypeId != null and pipeTypeId != 0">pipe_type_id = #{pipeTypeId},</if>
            <if test="serial != null">serial = #{serial},</if>
            <if test="piping != null">piping = #{piping},</if>
            <if test="farthestEnd != null">farthest_end = #{farthestEnd},</if>
