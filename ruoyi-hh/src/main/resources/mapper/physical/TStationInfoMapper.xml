            <if test="substationCode != null">#{substationCode},</if>
            <if test="sensorTypeName != null">#{sensorTypeName},</if>
            <if test="measurePointValueType != null">#{measurePointValueType},</if>
            <if test="measurePointValueUnit != null">#{measurePointValueUnit},</if>
            <if test="hightRange != null">#{hightRange},</if>
            <if test="lowRange != null">#{lowRange},</if>
            <if test="upWarn != null">#{upWarn},</if>
            <if test="upCancelWarn != null">#{upCancelWarn},</if>
            <if test="lowWarn != null">#{lowWarn},</if>
