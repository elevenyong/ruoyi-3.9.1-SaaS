    <sql id="selectTStationInfoVo">
        select id, roadway_id,drainage_unit_id,pipe_type_id,serial,measure_point_code, sys_code, substation_code, sensor_type_name,
               measure_point_value_type, measure_point_value_unit, hight_range, low_range, up_warn, up_cancel_warn,
               low_warn, low_cancel_warn, up_outage, up_onpower, low_outage, low_onpower, on_describe, stop_describe,
               measure_point_local, X, Y, Z, sensor_relevance, `time`,piping,farthest_end from t_station_info
    </sql>

    <select id="selectTStationInfoList" parameterType="TStationInfo" resultMap="TStationInfoResult">
        <include refid="selectTStationInfoVo"/>
        <where>
            <if test="id != null  and id != ''"> and id = #{id}</if>
            <if test="roadwayId != null  and roadwayId != 0"> and roadway_id = #{roadwayId}</if>
            <if test="drainageUnitId != null  and drainageUnitId != 0"> and drainage_unit_id = #{drainageUnitId}</if>
            <if test="pipeTypeId != null  and pipeTypeId != 0"> and pipe_type_id = #{pipeTypeId}</if>
            <if test="serial != null  and serial != ''"> and serial = #{serial}</if>
            <if test="measurePointCode != null  and measurePointCode != ''"> and measure_point_code = #{measurePointCode}</if>
            <if test="sysCode != null  and sysCode != ''"> and sys_code = #{sysCode}</if>
            <if test="substationCode != null  and substationCode != ''"> and substation_code = #{substationCode}</if>
            <if test="sensorTypeName != null  and sensorTypeName != ''"> and sensor_type_name=#{sensorTypeName} </if>
            <if test="measurePointValueType != null  and measurePointValueType != ''"> and measure_point_value_type = #{measurePointValueType}</if>
            <if test="measurePointValueUnit != null  and measurePointValueUnit != ''"> and measure_point_value_unit = #{measurePointValueUnit}</if>
            <if test="hightRange != null and hightRange!= 0.0 "> and hight_range = #{hightRange}</if>
            <if test="lowRange != null and lowRange!=0.0"> and low_range = #{lowRange}</if>
            <if test="upWarn != null and upWarn!=0.0"> and up_warn = #{upWarn}</if>
            <if test="upCancelWarn != null and upCancelWarn!=0.0"> and up_cancel_warn = #{upCancelWarn}</if>
            <if test="lowWarn != null and lowWarn!=0.0"> and low_warn = #{lowWarn}</if>
            <if test="lowCancelWarn != null and lowCancelWarn!=0.0"> and low_cancel_warn = #{lowCancelWarn}</if>
            <if test="upOutage != null and upOutage!=0.0"> and up_outage = #{upOutage}</if>
            <if test="upOnpower != null and upOnpower!=0.0"> and up_onpower = #{upOnpower}</if>
            <if test="lowOutage != null and lowOutage!=0.0"> and low_outage = #{lowOutage}</if>
            <if test="lowOnpower != null and lowOnpower!=0.0"> and low_onpower = #{lowOnpower}</if>
            <if test="onDescribe != null"> and on_describe = #{onDescribe}</if>
            <if test="stopDescribe != null"> and stop_describe = #{stopDescribe}</if>
            <if test="measurePointLocal != null  and measurePointLocal != ''"> and measure_point_local like concat('%', #{measurePointLocal}, '%')</if>
            <if test="X != null "> and X = #{x}</if>
            <if test="Y != null "> and Y = #{y}</if>
            <if test="Z != null "> and Z = #{z}</if>
            <if test="sensorRelevance != null  and sensorRelevance != ''"> and sensor_relevance = #{sensorRelevance}</if>
            <if test="time != null "> and time = #{time}</if>
            <if test="piping != null "> and piping = #{piping}</if>
            <if test="farthestEnd != null "> and farthest_end = #{farthestEnd}</if>
        </where>
    </select>

    <select id="selectTStationInfoById" parameterType="Integer" resultMap="TStationInfoResult">
        <include refid="selectTStationInfoVo"/>
        where id = #{id}
    </select>

