<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.hhhz.mapper.TParamBandDrillingMapper">

    <resultMap type="TParamBandDrilling" id="TParamBandDrillingResult">
        <result property="id" column="id"/>
        <result property="uid" column="uid"/>
        <result property="type" column="type"/>
        <result property="workingFaceId" column="working_face_id"/>
        <result property="coalinfoId" column="coalinfo_id"/>
        <result property="roadId" column="road_id"/>
        <result property="radius" column="radius"/>
        <result property="ls" column="ls"/>
        <result property="lx" column="lx"/>
        <result property="drillingType" column="drilling_type"/>
        <result property="hOffset" column="h_offset"/>
        <result property="wOffset" column="w_offset"/>
        <result property="originPositionDis" column="origin_position_dis"/>
        <result property="designLength" column="design_length"/>
        <result property="maxLength" column="max_length"/>
        <result property="minDipAngle" column="min_dip_angle"/>
        <result property="miningDesign" column="mining_design"/>
        <result property="createTime"    column="create_time"    />
        <result property="sign"    column="sign"    />
        <result property="schemeId"    column="scheme_id"    />
    </resultMap>

    <sql id="selectTParamBandDrillingVo">
        select id,
               uid,
               type,
               working_face_id,
               coalinfo_id,
               road_id,
               radius,
               ls,
               lx,
               drilling_type,
               h_offset,
               w_offset,
               origin_position_dis,
               design_length,
               max_length,
               min_dip_angle,
               mining_design,
               create_time,
               sign,
               scheme_id
        from t_param_band_drilling
    </sql>

    <select id="selectTParamBandDrillingList" parameterType="TParamBandDrilling" resultMap="TParamBandDrillingResult">
        <include refid="selectTParamBandDrillingVo"/>
        <where>
            <if test="uid != null ">and uid = #{uid}</if>
            <if test="type != null ">and type = #{type}</if>
            <if test="workingFaceId != null ">and working_face_id = #{workingFaceId}</if>
            <if test="coalinfoId != null ">and coalinfo_id = #{coalinfoId}</if>
            <if test="roadId != null ">and road_id = #{roadId}</if>
            <if test="radius != null ">and radius = #{radius}</if>
            <if test="ls != null ">and ls = #{ls}</if>
            <if test="lx != null ">and lx = #{lx}</if>
            <if test="drillingType != null ">and drilling_type = #{drillingType}</if>
            <if test="hOffset != null ">and h_offset = #{hOffset}</if>
            <if test="wOffset != null ">and w_offset = #{wOffset}</if>
            <if test="originPositionDis != null ">and origin_position_dis = #{originPositionDis}</if>
            <if test="designLength != null ">and design_length = #{designLength}</if>
            <if test="maxLength != null ">and max_length = #{maxLength}</if>
            <if test="minDipAngle != null ">and min_dip_angle = #{minDipAngle}</if>
            <if test="miningDesign != null ">and mining_design = #{miningDesign}</if>
            <if test="createTime != null ">and create_time = #{createTime}</if>
            <if test="sign != null ">and sign = #{sign}</if>
            <if test="schemeId != null ">and scheme_id = #{schemeId}</if>
        </where>
        order by id desc
    </select>

    <select id="selectTParamBandDrillingById" parameterType="Integer" resultMap="TParamBandDrillingResult">
        <include refid="selectTParamBandDrillingVo"/>
        where id = #{id}
    </select>

    <insert id="insertTParamBandDrilling" parameterType="TParamBandDrilling">
        insert into t_param_band_drilling
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="uid != null">uid,</if>
            <if test="type != null">type,</if>
            <if test="workingFaceId != null">working_face_id,</if>
            <if test="coalinfoId != null">coalinfo_id,</if>
            <if test="roadId != null">road_id,</if>
            <if test="radius != null">radius,</if>
            <if test="ls != null">ls,</if>
            <if test="lx != null">lx,</if>
            <if test="drillingType != null">drilling_type,</if>
            <if test="hOffset != null">h_offset,</if>
            <if test="wOffset != null">w_offset,</if>
            <if test="originPositionDis != null">origin_position_dis,</if>
            <if test="designLength != null">design_length,</if>
            <if test="maxLength != null">max_length,</if>
            <if test="minDipAngle != null">min_dip_angle,</if>
            <if test="miningDesign != null">mining_design,</if>
            <if test="sign != null">sign,</if>
            <if test="schemeId != null">scheme_id,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="uid != null">#{uid},</if>
            <if test="type != null">#{type},</if>
            <if test="workingFaceId != null">#{workingFaceId},</if>
            <if test="coalinfoId != null">#{coalinfoId},</if>
            <if test="roadId != null">#{roadId},</if>
            <if test="radius != null">#{radius},</if>
            <if test="ls != null">#{ls},</if>
            <if test="lx != null">#{lx},</if>
            <if test="drillingType != null">#{drillingType},</if>
            <if test="hOffset != null">#{hOffset},</if>
            <if test="wOffset != null">#{wOffset},</if>
            <if test="originPositionDis != null">#{originPositionDis},</if>
            <if test="designLength != null">#{designLength},</if>
            <if test="maxLength != null">#{maxLength},</if>
            <if test="minDipAngle != null">#{minDipAngle},</if>
            <if test="miningDesign != null">#{miningDesign},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="sign != null">#{sign},</if>
            <if test="schemeId != null">#{schemeId},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTParamBandDrilling" parameterType="TParamBandDrilling">
        update t_param_band_drilling
        <trim prefix="SET" suffixOverrides=",">
            <if test="uid != null">uid = #{uid},</if>
            <if test="type != null">type = #{type},</if>
            <if test="workingFaceId != null">working_face_id = #{workingFaceId},</if>
            <if test="coalinfoId != null">coalinfo_id = #{coalinfoId},</if>
            <if test="roadId != null">road_id = #{roadId},</if>
            <if test="radius != null">radius = #{radius},</if>
            <if test="ls != null">ls = #{ls},</if>
            <if test="lx != null">lx = #{lx},</if>
            <if test="drillingType != null">drilling_type = #{drillingType},</if>
            <if test="hOffset != null">h_offset = #{hOffset},</if>
            <if test="wOffset != null">w_offset = #{wOffset},</if>
            <if test="originPositionDis != null">origin_position_dis = #{originPositionDis},</if>
            <if test="designLength != null">design_length = #{designLength},</if>
            <if test="maxLength != null">max_length = #{maxLength},</if>
            <if test="minDipAngle != null">min_dip_angle = #{minDipAngle},</if>
            <if test="miningDesign != null">mining_design = #{miningDesign},</if>
            <if test="sign != null">sign = #{sign},</if>
            <if test="schemeId != null">scheme_id = #{schemeId},</if>
        </trim>
        where id = #{id}
    </update>


    <delete id="deleteTParamBandDrillingById" parameterType="Integer">
        delete
        from t_param_band_drilling
        where id = #{id}
    </delete>

    <delete id="deleteTParamBandDrillingByIds" parameterType="String">
        delete from t_param_band_drilling where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!--取最新一条数据-->
    <select id="getLastOne" resultMap="TParamBandDrillingResult">
        select * from t_param_band_drilling order by id desc limit 0,1
    </select>

    <!--确定方案：将数据库中的标识由0改成1-->
    <update id="updateSign" >
        update t_param_band_drilling set sign =1 where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>
</mapper>
