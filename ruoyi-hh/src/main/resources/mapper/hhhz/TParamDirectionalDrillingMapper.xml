<mapper namespace="com.ruoyi.hh.hhhz.mapper.TParamDirectionalDrillingMapper">

    <resultMap type="TParamDirectionalDrilling" id="TParamDirectionalDrillingResult">
        <result property="id"    column="id"    />
        <result property="uid"    column="uid"    />
        <result property="workingFaceId"    column="working_face_id"    />
        <result property="roadId"    column="road_id"    />
        <result property="type"    column="type"    />
        <result property="radius"    column="radius"    />
        <result property="controlLengthMin"    column="control_length_min"    />
        <result property="controlLengthMax"    column="control_length_max"    />
        <result property="topOrBottom"    column="top_or_bottom"    />
        <result property="distanceOfRoadStart"    column="distance_of_road_start"    />
        <result property="heightToTop"    column="height_to_top"    />
        <result property="distanceFromWindRoadway"    column="distance_from_wind_roadway"    />
        <result property="distanceFromCutRoadway"    column="distance_from_cut_roadway"    />
        <result property="inOrOut"    column="in_or_out"    />
