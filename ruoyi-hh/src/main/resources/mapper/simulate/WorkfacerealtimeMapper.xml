<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.simulate.mapper.WorkfacerealtimeMapper">
    
    <resultMap type="Workfacerealtime" id="WorkfacerealtimeResult">
        <result property="id"    column="id"    />
        <result property="workfaceId"    column="workface_id"    />
        <result property="drainageUnitId"    column="drainage_unit_id"    />
        <result property="measurePointId"    column="measure_point_id"    />
        <result property="mixTureFlow"    column="mix_ture_flow"    />
        <result property="pureFlow"    column="pure_flow"    />
        <result property="temperature"    column="temperature"    />
        <result property="ch4Concentration"    column="ch4_concentration"    />
        <result property="coConcentration"    column="co_concentration"    />
        <result property="negativePressure"    column="negative_pressure"    />
    </resultMap>

    <sql id="selectWorkfacerealtimeVo">
        select id, workface_id, drainage_unit_id,measure_point_id, mix_ture_flow, pure_flow, temperature, ch4_concentration, co_concentration, negative_pressure from workfacerealtime
    </sql>

    <select id="selectWorkfacerealtimeList" parameterType="Workfacerealtime" resultMap="WorkfacerealtimeResult">
        <include refid="selectWorkfacerealtimeVo"/>
        <where>
            <if test="id!=null and id!=0">and d.id=#{id}</if>
            <if test="workfaceId != null "> and workface_id = #{workfaceId}</if>
            <if test="drainageUnitId != null "> and drainage_unit_id = #{drainageUnitId}</if>
            <if test="measurePointId != null "> and measure_point_id = #{measurePointId}</if>
            <if test="mixTureFlow != null "> and mix_ture_flow = #{mixTureFlow}</if>
            <if test="pureFlow != null "> and pure_flow = #{pureFlow}</if>
            <if test="temperature != null "> and temperature = #{temperature}</if>
            <if test="ch4Concentration != null "> and ch4_concentration = #{ch4Concentration}</if>
            <if test="coConcentration != null "> and co_concentration = #{coConcentration}</if>
            <if test="negativePressure != null "> and negative_pressure = #{negativePressure}</if>
        </where>
    </select>
    
    <select id="selectWorkfacerealtimeById" parameterType="Integer" resultMap="WorkfacerealtimeResult">
        <include refid="selectWorkfacerealtimeVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertWorkfacerealtime" parameterType="Workfacerealtime" useGeneratedKeys="true" keyProperty="id">
        insert into workfacerealtime
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="workfaceId != null">workface_id,</if>
            <if test="drainageUnitId != null">drainage_unit_id,</if>
            <if test="measurePointId != null">measure_point_id,</if>
            <if test="mixTureFlow != null">mix_ture_flow,</if>
            <if test="pureFlow != null">pure_flow,</if>
            <if test="temperature != null">temperature,</if>
            <if test="ch4Concentration != null">ch4_concentration,</if>
            <if test="coConcentration != null">co_concentration,</if>
            <if test="negativePressure != null">negative_pressure,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="workfaceId != null">#{workfaceId},</if>
            <if test="drainageUnitId != null">#{drainageUnitId},</if>
            <if test="measurePointId != null">#{measurePointId},</if>
            <if test="mixTureFlow != null">#{mixTureFlow},</if>
            <if test="pureFlow != null">#{pureFlow},</if>
            <if test="temperature != null">#{temperature},</if>
            <if test="ch4Concentration != null">#{ch4Concentration},</if>
            <if test="coConcentration != null">#{coConcentration},</if>
            <if test="negativePressure != null">#{negativePressure},</if>
         </trim>
    </insert>

    <update id="updateWorkfacerealtime" parameterType="Workfacerealtime">
        update workfacerealtime
        <trim prefix="SET" suffixOverrides=",">
            <if test="workfaceId != null">workface_id = #{workfaceId},</if>
            <if test="drainageUnitId != null">drainage_unit_id = #{drainageUnitId},</if>
            <if test="measurePointId != null">measure_point_id = #{measurePointId},</if>
            <if test="mixTureFlow != null">mix_ture_flow = #{mixTureFlow},</if>
            <if test="pureFlow != null">pure_flow = #{pureFlow},</if>
            <if test="temperature != null">temperature = #{temperature},</if>
            <if test="ch4Concentration != null">ch4_concentration = #{ch4Concentration},</if>
            <if test="coConcentration != null">co_concentration = #{coConcentration},</if>
            <if test="negativePressure != null">negative_pressure = #{negativePressure},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteWorkfacerealtimeById" parameterType="Integer">
        delete from workfacerealtime where id = #{id}
    </delete>

    <delete id="deleteWorkfacerealtimeByIds" parameterType="String">
        delete from workfacerealtime where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <!--根据工作面ID查询传感器模拟的实时数据-->
    <select id="getWorkFaceExtractionInfoById" resultType="com.ruoyi.hh.simulate.domain.Workfacerealtime" parameterType="java.lang.Integer">
        SELECT r.*,w.begindrainage_date,w.working_face_name AS workfacename
        from workfacerealtime r
        LEFT JOIN t_working_face w ON w.id = r.workface_id
        where r.drainage_unit_id is NULL AND r.workface_id = #{workfaceId}
    </select>
</mapper>