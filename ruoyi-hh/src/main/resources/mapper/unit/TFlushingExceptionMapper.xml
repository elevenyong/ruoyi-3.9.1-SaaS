<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.util.mapper.TFlushingExceptionMapper">

    <resultMap type="TFlushingException" id="TFlushingExceptionResult">
        <result property="id"    column="Id"    />
        <result property="exceptionPhenomena"    column="exception_phenomena"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTFlushingExceptionVo">
        select id, exception_phenomena, create_by, create_time, update_by, update_time, remark from t_flushing_exception
    </sql>

    <select id="selectTFlushingExceptionList" parameterType="TFlushingException" resultMap="TFlushingExceptionResult">
        <include refid="selectTFlushingExceptionVo"/>
        <where>
            <if test="id!=null and id!=0">and id=#{id}</if>
            <if test="exceptionPhenomena != null  and exceptionPhenomena != ''">and exception_phenomena =
                #{exceptionPhenomena}
            </if>
        </where>
    </select>

    <select id="selectTFlushingExceptionById" parameterType="java.lang.Integer" resultMap="TFlushingExceptionResult">
        <include refid="selectTFlushingExceptionVo"/>
        where Id = #{id}
    </select>

    <insert id="insertTFlushingException" parameterType="TFlushingException">
        insert into t_flushing_exception
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">Id,</if>
            <if test="exceptionPhenomena != null">exception_phenomena,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="exceptionPhenomena != null">#{exceptionPhenomena},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTFlushingException" parameterType="TFlushingException">
        update t_flushing_exception
        <trim prefix="SET" suffixOverrides=",">
            <if test="exceptionPhenomena != null">exception_phenomena = #{exceptionPhenomena},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where Id = #{id}
    </update>

    <delete id="deleteTFlushingExceptionById" parameterType="Long">
        delete from t_flushing_exception where id = #{id}
    </delete>

    <delete id="deleteTFlushingExceptionByIds" parameterType="java.util.List">
        delete from t_flushing_exception where id in
        <foreach item="id" collection="List" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <select id="selectTFlushingExceptionVo" resultType="com.ruoyi.hh.util.domain.TFlushingException">
        <include refid="selectTFlushingExceptionVo"/>
    </select>
</mapper>