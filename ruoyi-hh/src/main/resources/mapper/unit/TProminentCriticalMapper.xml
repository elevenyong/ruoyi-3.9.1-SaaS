<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.util.mapper.TProminentCriticalMapper">

    <resultMap type="TProminentCritical" id="TProminentCriticalResult">
        <result property="id"    column="id"    />
        <result property="indicators"    column="indicators"    />
        <result property="unit"    column="unit"    />
        <result property="criticalValue"    column="critical_value"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTProminentCriticalVo">
        select id, indicators, unit, critical_value, create_by, create_time, update_by, update_time, remark from t_prominent_critical
    </sql>

    <select id="selectTProminentCriticalList" parameterType="TProminentCritical" resultMap="TProminentCriticalResult">
        <include refid="selectTProminentCriticalVo"/>
        <where>
            <if test="id!=null and id!=0">and id=#{id}</if>
            <if test="indicators != null  and indicators != ''"> and indicators = #{indicators}</if>
            <if test="unit != null  and unit != ''"> and unit = #{unit}</if>
            <if test="criticalValue != null  and criticalValue != ''"> and critical_value = #{criticalValue}</if>
        </where>
    </select>

    <select id="selectTProminentCriticalById" parameterType="java.lang.Integer" resultMap="TProminentCriticalResult">
        <include refid="selectTProminentCriticalVo"/>
        where id = #{id}
    </select>

    <insert id="insertTProminentCritical" parameterType="TProminentCritical" useGeneratedKeys="true" keyProperty="id">
        insert into t_prominent_critical
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="indicators != null">indicators,</if>
            <if test="unit != null">unit,</if>
            <if test="criticalValue != null">critical_value,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="indicators != null">#{indicators},</if>
            <if test="unit != null">#{unit},</if>
            <if test="criticalValue != null">#{criticalValue},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTProminentCritical" parameterType="TProminentCritical">
        update t_prominent_critical
        <trim prefix="SET" suffixOverrides=",">
            <if test="indicators != null">indicators = #{indicators},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="criticalValue != null">critical_value = #{criticalValue},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTProminentCriticalById" parameterType="java.lang.Integer">
        delete from t_prominent_critical where id = #{id}
    </delete>

    <delete id="deleteTProminentCriticalByIds" parameterType="java.util.List">
        delete from t_prominent_critical where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <select id="getPageList" resultType="com.ruoyi.hh.util.domain.TProminentCritical">
        <include refid="selectTProminentCriticalVo"/>
    </select>
</mapper>