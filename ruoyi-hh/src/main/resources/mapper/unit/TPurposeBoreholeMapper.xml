<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hh.util.mapper.TPurposeBoreholeMapper">

    <resultMap type="TPurposeBorehole" id="TPurposeBoreholeResult">
        <result property="id"    column="id"    />
        <result property="purposeBorehole"    column="purpose_borehole"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTPurposeBoreholeVo">
        select id, purpose_borehole, create_by, create_time, update_by, update_time, remark from t_purpose_borehole
    </sql>

    <select id="selectTPurposeBoreholeList" parameterType="TPurposeBorehole" resultMap="TPurposeBoreholeResult">
        <include refid="selectTPurposeBoreholeVo"/>
        <where>
            <if test="id!=null and id!=0">and id=#{id}</if>
            <if test="purposeBorehole != null  and purposeBorehole != ''"> and purpose_borehole = #{purposeBorehole}</if>
        </where>
    </select>

    <select id="selectTPurposeBoreholeById" parameterType="Integer" resultMap="TPurposeBoreholeResult">
        <include refid="selectTPurposeBoreholeVo"/>
        where Id = #{id}
    </select>

    <insert id="insertTPurposeBorehole" parameterType="TPurposeBorehole" useGeneratedKeys="true" keyProperty="id">
        insert into t_purpose_borehole
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="purposeBorehole != null">purpose_borehole,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="purposeBorehole != null">#{purposeBorehole},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
    </insert>

    <update id="updateTPurposeBorehole" parameterType="TPurposeBorehole">
        update t_purpose_borehole
        <trim prefix="SET" suffixOverrides=",">
            <if test="purposeBorehole != null">purpose_borehole = #{purposeBorehole},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time =
            <!-- 根据数据库类型选择时间函数 -->
            <if test="_databaseId.contains('mysql')">NOW()</if>
            <if test="_databaseId.contains('sqlite')">datetime('now', 'localtime')</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTPurposeBoreholeById" parameterType="java.lang.Integer">
        delete from t_purpose_borehole where id = #{id}
    </delete>

    <delete id="deleteTPurposeBoreholeByIds" parameterType="java.util.List">
        delete from t_purpose_borehole where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <insert id="insertTPurposeBoreholeList" parameterType="java.util.List">
        insert IGNORE into t_purpose_borehole(purpose_borehole)
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (
            #{item.purposeBorehole}
            )
        </foreach>
    </insert>
    <!--分页查询-->
    <select id="getPageList" resultType="com.ruoyi.hh.util.domain.TPurposeBorehole">
        select * from t_purpose_borehole
    </select>
    <!--根据钻孔用途查询ID-->
    <select id="getIdByPurposeBorehole" parameterType="string" resultType="java.lang.Integer">
        select Id from t_purpose_borehole where purpose_borehole = #{purposeBorehole}
    </select>
</mapper>